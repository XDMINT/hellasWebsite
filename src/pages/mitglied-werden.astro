---
import SiteLayout from "../layouts/siteLayout.astro";
import { underlinedTitleClass, bodyClass, smallClass, accentBar, box, card, ctaBtn as btnPrimary, secondaryBtn as btnSecondary } from "../lib/styles";

const pdfHref = "/downloads/aufnahmeAntrag.pdf";
---

<SiteLayout
    pageTitle="Mitglied werden | WSV Hellas Gießen - Jetzt Beitreten"
    description="Werde Mitglied beim WSV Hellas 1920 Gießen e.V.! Faire Beiträge, familiäres Vereinsleben, Rudern und Drachenboot. Aufnahmeantrag hier downloaden."
    keywords="Mitglied werden Gießen, Ruderverein beitreten, WSV Hellas Mitgliedschaft, Vereinsbeitritt Gießen, Ruderkurs anmelden, Drachenboot Mitglied"
    showHero={false}
>
    <section class="bg-white">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
            <div class={box}>
                <div class="text-center">
                    <h1 class={underlinedTitleClass}>Mitglied werden</h1>
                    <p class={"mt-5 mx-auto max-w-3xl " + bodyClass}>
                        Schön, dass du dich für uns interessierst! Der Einstieg ist unkompliziert: Antrag herunterladen,
                        ausfüllen und an uns zurücksenden – wir melden uns bei Rückfragen.
                    </p>
                </div>

                <div class="mt-10 grid gap-6 lg:grid-cols-3">
                    {/* Schritte */}
                    <div class={card}>
                        <div class={accentBar}></div>
                        <h2 class="mt-4 font-albert text-xl sm:text-2xl font-extrabold tracking-tight text-neutral-900">
                            So geht’s
                        </h2>
                        <ol class="mt-4 space-y-3 font-barlow text-sm sm:text-base text-neutral-700">
                            <li><span class="font-semibold">1.</span> Mitgliedsantrag herunterladen</li>
                            <li><span class="font-semibold">2.</span> Ausfüllen & unterschreiben</li>
                            <li><span class="font-semibold">3.</span> Per E-Mail oder persönlich abgeben</li>
                        </ol>
                        <div class="mt-6 flex flex-col sm:flex-row lg:flex-col gap-3">
                            <a class={btnPrimary} href={pdfHref} download>Mitgliedsantrag (PDF)</a>
                            <a class={btnSecondary} href="/kontakt">Fragen? Kontakt</a>
                        </div>
                    </div>

                    {/* Hinweise */}
                    <div class={card}>
                        <div class={accentBar}></div>
                        <h2 class="mt-4 font-albert text-xl sm:text-2xl font-extrabold tracking-tight text-neutral-900">
                            Hinweise
                        </h2>
                        <ul class="mt-4 space-y-3 font-barlow text-sm sm:text-base text-neutral-700">
                            <li>• Probetraining ist nach Absprache möglich.</li>
                            <li>• Für Kinder & Jugendliche gibt es eigene Gruppen.</li>
                            <li>• Infos zu Zeiten findest du bei den Trainingszeiten.</li>
                        </ul>
                        <div class="mt-6 flex flex-col sm:flex-row lg:flex-col gap-3">
                            <a class={btnPrimary} href="/trainingszeiten">Trainingszeiten</a>
                            <a class={btnSecondary} href="/downloads/Vereinssatzung2019.pdf" target="_blank">Vereinssatzung (PDF)</a>
                        </div>
                    </div>

                    {/* Rückgabe */}
                    <div class={card}>
                        <div class={accentBar}></div>
                        <h2 class="mt-4 font-albert text-xl sm:text-2xl font-extrabold tracking-tight text-neutral-900">
                            Rückgabe
                        </h2>
                        <p class={"mt-4 " + smallClass}>
                            Schick den ausgefüllten Antrag an
                            <a class="text-blue-700 font-semibold hover:underline" href="mailto:kontakt@wsv-hellas.de"> kontakt@wsv-hellas.de</a>
                            oder gib ihn am Bootshaus ab (Wißmarer Weg 125, 35396 Gießen).
                        </p>
                        <p class={"mt-3 " + smallClass}>
                            Tipp: Wenn du Fragen zur passenden Gruppe hast, schreib uns kurz – wir helfen dir beim Einstieg.
                        </p>
                        <div class="mt-6 flex flex-col sm:flex-row lg:flex-col gap-3">
                            <a class={btnPrimary} href="/kontakt">Jetzt anfragen</a>
                            <a class={btnSecondary} href="/vorstand">Ansprechpartner</a>
                        </div>
                    </div>
                </div>

                {/* Mitgliedsbeiträge */}
                <div class="mt-8 bg-white rounded-2xl ring-1 ring-black/10 overflow-hidden">
                    <div class="px-6 py-5 sm:px-10 sm:py-6 bg-neutral-50">
                        <div class="font-albert text-xl sm:text-2xl font-extrabold tracking-tight text-neutral-900">
                            Mitgliedsbeiträge
                        </div>
                    </div>

                    <div class="p-6 sm:p-8">
                        <div class={accentBar + " mb-6"}></div>

                        <div class="hidden sm:block overflow-x-auto">
                            <table class="w-full border-separate border-spacing-0 overflow-hidden rounded-2xl bg-white ring-1 ring-black/10">
                                <thead class="bg-neutral-50">
                                <tr class="text-left">
                                    <th class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-800">Mitgliedschaft</th>
                                    <th class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-800">Monatlicher Beitrag</th>
                                </tr>
                                </thead>
                                <tbody class="divide-y divide-black/10">
                                <tr>
                                    <td class="px-4 py-3 font-barlow text-sm text-neutral-800">
                                        Einzelmitgliedschaft (Kinder, Jugendliche, Auszubildende, Studenten)
                                    </td>
                                    <td class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-900 whitespace-nowrap">11,00 €</td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-3 font-barlow text-sm text-neutral-800">
                                        Einzelmitgliedschaft Erwachsene (ab dem 18. Lebensjahr)
                                    </td>
                                    <td class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-900 whitespace-nowrap">13,00 €</td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-3 font-barlow text-sm text-neutral-800">Familienbeitrag (2 Personen)</td>
                                    <td class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-900 whitespace-nowrap">18,00 €</td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-3 font-barlow text-sm text-neutral-800">Familienbeitrag (3 Personen)</td>
                                    <td class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-900 whitespace-nowrap">22,00 €</td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-3 font-barlow text-sm text-neutral-800">Familienbeitrag (4 Personen und mehr)</td>
                                    <td class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-900 whitespace-nowrap">25,00 €</td>
                                </tr>
                                </tbody>
                            </table>
                        </div>

                        {/* Mobile */}
                        <div class="grid gap-3 sm:hidden">
                            {[
                                { t: "Einzel (Kinder/Jugend/Azubi/Student)", p: "11,00 €" },
                                { t: "Einzel Erwachsene (ab 18)", p: "13,00 €" },
                                { t: "Familie (2 Personen)", p: "18,00 €" },
                                { t: "Familie (3 Personen)", p: "22,00 €" },
                                { t: "Familie (4+ Personen)", p: "25,00 €" },
                            ].map((row) => (
                                    <div class="bg-neutral-100 rounded-2xl ring-1 ring-black/10 p-4 w-full max-w-full overflow-hidden">
                                        <div class={accentBar}></div>

                                        <div class="mt-4 flex items-start justify-between gap-3">
                                            {/* wichtig: min-w-0 damit der Text wirklich umbrechen darf */}
                                            <div class="min-w-0">
                                                <div class="font-barlow text-sm font-semibold text-neutral-800 break-words">
                                                    {row.t}
                                                </div>
                                            </div>

                                            {/* Preis: immer sichtbar, kein Umbruch */}
                                            <div class="shrink-0 text-right">
                                                <div class="font-barlow text-base font-extrabold text-neutral-900 whitespace-nowrap">
                                                    {row.p}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                            ))}
                        </div>


                        {/* Aufnahmegebühr */}
                        <div class="mt-6 bg-neutral-100 rounded-2xl ring-1 ring-black/10 p-5">
                            <div class={accentBar}></div>
                            <div class="mt-4 font-albert text-lg sm:text-xl font-extrabold text-neutral-900">
                                Aufnahmegebühr
                            </div>
                            <p class={"mt-2 " + bodyClass}>
                                Pro Aufnahmevorgang (Einzelperson bzw. Familie): <span class="font-semibold text-neutral-900">20,00 €</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</SiteLayout>

