---
import SiteLayout from "../layouts/siteLayout.astro";
import SectionIntro from "../components/SectionIntro.astro";
import CtaSection from "../components/CtaSection.astro";
import OptimizedImg from "../components/OptimizedImg.astro";
import RuderAmpel from "../components/ruderampel.astro";
import { drachenbootAction, drachenbootHinten, drachenbootNah } from "../assets/images";
import { ctaBtn, secondaryBtn, bodyClass, smallClass } from "../lib/styles";
---

<SiteLayout
        pageTitle="Drachenboot in Gießen | WSV Hellas - Training & Events"
        description="Drachenboot beim WSV Hellas Gießen. Teamgeist, Action und Spaß auf der Lahn. Ideal für Firmenevents, Teambuilding und Sportbegeisterte. Schnuppern jederzeit möglich!"
        keywords="Drachenboot Gießen, Drachenboot Cup, Drachenboot Lahn, Drachenboot Training, Firmenevents Drachenboot, Teambuilding Gießen, Drachenboot Schnuppern, Wassersport Team, Drachenboot Wettkampf"
        heroTitle="Drachenboot"
        heroSubtitle="Team, Takt und Tempo – gemeinsam im Boot"
        heroImage={drachenbootAction}
        showHero={true}
        heroImageCredit="© Dieter Nuber"
>
    <RuderAmpel slot="heroTopLeft" variant="overlay" />

    <div id="top" class="sr-only">Top</div>

    <!-- Intro -->
    <SectionIntro title="Was ist Drachenboot?">
        <p class={bodyClass}>
            Drachenboot ist Mannschaftssport auf dem Wasser: Ein großes Boot, viele Paddel – und ein gemeinsamer Rhythmus.
            Entscheidend sind Timing, Technik und Teamgeist. Genau das macht Drachenboot so besonders: Man wächst schnell als
            Crew zusammen und merkt sofort, wie viel Geschwindigkeit durch gutes Zusammenspiel entsteht.
        </p>

        <p class={"mt-4 " + bodyClass}>
            Bei uns steht das Miteinander im Vordergrund – mit Spaß am Training, klaren Abläufen und dem Ziel,
            als Team besser zu werden. Ob du neu reinschnuppern möchtest oder schon Erfahrung hast: Du bist willkommen.
        </p>

        <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a class={ctaBtn} href="/kontakt">Probetraining anfragen</a>
            <a class={secondaryBtn} href="/trainingszeiten">Trainingszeiten</a>
        </div>

        <p class={"mt-4 " + smallClass}>
            Tipp: Sportsachen, Trinkflasche und ggf. Wechselshirt reichen für den Einstieg völlig aus.
        </p>
    </SectionIntro>

    <!-- Bild + Trainingsinfos -->
    <section class="bg-white">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 sm:py-14">
            <div class="grid gap-8 lg:grid-cols-12 lg:items-center">
                <!-- Bild 1 -->
                <div class="lg:col-span-6">
                    <div class="overflow-hidden rounded-2xl ring-1 ring-black/10 shadow-sm bg-neutral-200">
                        <div class="relative aspect-[16/10]">
                            <OptimizedImg
                                    src={drachenbootHinten}
                                    alt="Drachenboot Training"
                                    className="absolute inset-0 h-full w-full"
                                    loading="lazy"
                                    widths={[400, 640, 960]}
                                    sizes="(min-width: 1024px) 50vw, 100vw"
                            />
                        </div>
                    </div>
                    <p class={"mt-3 " + smallClass}>Bild: ©No4Any</p>
                </div>

                <!-- Textblock -->
                <div class="lg:col-span-6">
                    <div class="bg-neutral-100 rounded-2xl px-6 py-8 sm:px-8 sm:py-10">
                        <h3 class="font-albert text-2xl sm:text-3xl font-extrabold tracking-tight text-neutral-900">
                            Training & Ablauf
                        </h3>

                        <p class={"mt-3 " + bodyClass}>
                            Im Training arbeiten wir an Grundtechnik, Schlagrhythmus und Abstimmung im Boot.
                            Zusätzlich gehören kurze Belastungen und längere Ausfahrten dazu – je nach Saison und Zielsetzung.
                        </p>

                        <ul class="mt-5 space-y-2 font-barlow text-base text-neutral-700">
                            <li>• Technik: saubere Paddelführung & gemeinsamer Takt</li>
                            <li>• Team: Kommandos, Sitzpositionen, Bootsgefühl</li>
                            <li>• Fitness: Ausdauer und Kraft – passend dosiert</li>
                        </ul>

                        <p class={"mt-5 " + smallClass}>
                            Du musst kein Profi sein – wichtig ist die Bereitschaft, im Team zu arbeiten und regelmäßig zu kommen.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Wettkämpfe / Events + Bild 2 -->
    <section class="bg-white">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 sm:py-14">
            <div class="bg-neutral-100 rounded-2xl px-6 py-10 sm:px-10 sm:py-12">
                <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
                    <div class="lg:col-span-7">
                        <h3 class="font-albert text-2xl sm:text-3xl font-extrabold tracking-tight text-neutral-900">
                            Regatten, Events & Gemeinschaft
                        </h3>

                        <p class={"mt-3 " + bodyClass}>
                            Drachenboot lebt auch von Events: gemeinsame Trainings, Wettkämpfe und Vereinsaktionen.
                            Ob Regatta-Atmosphäre oder einfach ein gutes Training mit der Crew – das Gemeinschaftsgefühl steht im Mittelpunkt.
                        </p>

                        <p class={"mt-4 " + bodyClass}>
                            Wenn du Lust hast, dich sportlich zu steigern, können auch Regatten und Teamziele ein Thema sein.
                            Gleichzeitig ist Drachenboot perfekt, um einfach regelmäßig aufs Wasser zu kommen und gemeinsam aktiv zu sein.
                        </p>

                        <div class="mt-6 flex flex-col sm:flex-row gap-3">
                            <a class={ctaBtn} href="/mitglied-werden">Mitmachen</a>
                            <a class={secondaryBtn} href="/news">Aktuelle Berichte</a>
                        </div>
                    </div>

                    <!-- Bild 2 -->
                    <div class="lg:col-span-5">
                        <div class="overflow-hidden rounded-2xl ring-1 ring-black/10 shadow-sm bg-neutral-200">
                            <div class="relative aspect-[4/3]">
                                <OptimizedImg
                                        src={drachenbootNah}
                                        alt="Drachenboot Event"
                                        className="absolute inset-0 h-full w-full"
                                        loading="lazy"
                                        widths={[400, 640, 960]}
                                        sizes="(min-width: 1024px) 50vw, 100vw"
                                />
                            </div>
                        </div>
                        <p class={"mt-3 " + smallClass}>Bild: ©No4Any</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Kurzinfo -->
    <section class="bg-white">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-14">
            <div class="bg-neutral-100 rounded-2xl px-6 py-10 sm:px-10 sm:py-12">
                <h3 class="font-albert text-2xl sm:text-3xl font-extrabold tracking-tight text-neutral-900 text-center">
                    Kurz & knapp
                </h3>

                <div class="mt-8 grid gap-6 md:grid-cols-3">
                    <div class="bg-white rounded-2xl ring-1 ring-black/10 p-5">
                        <div class="h-1 w-14 rounded-full bg-blue-500/90"></div>
                        <div class="mt-4 font-albert text-lg font-extrabold text-neutral-900">Für wen?</div>
                        <p class={"mt-2 " + smallClass}>Für alle, die Teamsport mögen – egal ob Einsteiger oder mit Erfahrung.</p>
                    </div>

                    <div class="bg-white rounded-2xl ring-1 ring-black/10 p-5">
                        <div class="h-1 w-14 rounded-full bg-blue-500/90"></div>
                        <div class="mt-4 font-albert text-lg font-extrabold text-neutral-900">Was braucht man?</div>
                        <p class={"mt-2 " + smallClass}>Sportkleidung, Trinkflasche – ggf. Wechselshirt. Paddel/Boot stellen wir.</p>
                    </div>

                    <div class="bg-white rounded-2xl ring-1 ring-black/10 p-5">
                        <div class="h-1 w-14 rounded-full bg-blue-500/90"></div>
                        <div class="mt-4 font-albert text-lg font-extrabold text-neutral-900">Wie starten?</div>
                        <p class={"mt-2 " + smallClass}>Einfach Kontakt aufnehmen und zum Probetraining kommen.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</SiteLayout>

