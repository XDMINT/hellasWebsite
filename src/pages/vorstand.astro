---
// src/pages/vorstand/index.astro
import SiteLayout from "../layouts/siteLayout.astro";
import CtaSection from "../components/CtaSection.astro";
import { accentBar, bodyClass, smallClass, ctaBtn, secondaryBtn, underlinedTitleClass } from "../lib/styles";

type PersonRole = { role: string; name: string; note?: string };

const executive: PersonRole[] = [
    { role: "Vorsitzender – Verwaltung", name: "Michael Berkowski" },
    { role: "Vorsitzende – Sport", name: "Genia Frackenpohl" },
    { role: "Kassiererin", name: "Bettina Freese" },
];

const secretariat: PersonRole[] = [
    { role: "1. Schriftführerin", name: "Christina Kropf" },
    { role: "2. Schriftführerin", name: "Susanne Eckl" },
];

const sportAndYouth: PersonRole[] = [
    { role: "Kindeswohlbeauftragte", name: "Claudia Lutz" },
    { role: "Jugendleiter", name: "Tim Titus Günther" },
    { role: "Kinder- und Jugendrudern – Trainer", name: "Andreas Schäfer / Stephan Klauke" },
    { role: "Drachenbootkapitän", name: "Christopher Mauritz" },
    { role: "Freizeit- und Breitensportwart", name: "Holger Weis" },
];

const opsAndMedia: PersonRole[] = [
    { role: "Haus- und Platzwart", name: "Andreas Schäfer" },
    { role: "Boots- und Materialwart", name: "Jan Schwing / Thorsten Hopp" },
    { role: "Öffentlichkeitsarbeit", name: "-" },
];

const sections: { title: string; items: PersonRole[] }[] = [
    { title: "Geschäftsführender Vorstand", items: executive },
    { title: "Schriftführung", items: secretariat },
    { title: "Sport & Jugend", items: sportAndYouth },
    { title: "Organisation & Öffentlichkeitsarbeit", items: opsAndMedia },
];
---

<SiteLayout
    pageTitle="Vorstand & Ansprechpartner | WSV Hellas Gießen"
    description="Der Vorstand des WSV Hellas 1920 Gießen e.V. - Ansprechpartner für Rudern, Drachenboot, Jugend und Vereinsangelegenheiten."
    keywords="Vorstand WSV Hellas, Ruderverein Vorstand Gießen, Ansprechpartner Wassersport, Vereinsführung Gießen"
    showHero={false}
>
    <!-- Kopfbereich -->
    <section class="bg-white">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
            <div class="bg-neutral-100 rounded-2xl px-6 py-10 sm:px-10 sm:py-12">
                <div class="text-center">
                    <h1 class={underlinedTitleClass}>Vorstand</h1>
                    <p class={"mt-5 mx-auto max-w-3xl " + bodyClass}>
                        Hier findest du unsere aktuellen Ansprechpartner:innen.
                    </p>
                    <p class={"mt-3 " + smallClass}>
                        Für allgemeine Anfragen nutze am besten unser Kontaktformular.
                    </p>

                    <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
                        <a class={ctaBtn} href="/kontakt">Kontakt</a>
                        <a class={secondaryBtn} href="/trainingszeiten">Trainingszeiten</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Vorstand: Sektionen -->
    <section class="bg-white">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-6">
            <div class="grid gap-6 lg:grid-cols-2">
                {sections.map((sec) => (
                        <div class="bg-neutral-100 rounded-2xl ring-1 ring-black/10 px-6 py-8 sm:px-10 sm:py-10">
                            <div class={accentBar}></div>
                            <h2 class="mt-4 font-albert text-xl sm:text-2xl font-extrabold tracking-tight text-neutral-900">
                                {sec.title}
                            </h2>

                            <dl class="mt-6 space-y-4">
                                {sec.items.map((it) => (
                                        <div class="bg-white rounded-2xl ring-1 ring-black/10 p-5">
                                            <dt class="font-barlow text-sm font-semibold text-neutral-600">{it.role}</dt>
                                            <dd class="mt-1 font-albert text-lg font-extrabold text-neutral-900">{it.name}</dd>
                                            {it.note && <dd class={"mt-2 " + smallClass}>{it.note}</dd>}
                                        </div>
                                ))}
                            </dl>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <CtaSection
        title="Du möchtest mitmachen oder hast Fragen?"
        body="Schreib uns – wir leiten dein Anliegen an die richtige Person weiter."
        primaryHref="/kontakt"
        primaryLabel="Jetzt schreiben"
        secondaryHref="/mitglied-werden"
        secondaryLabel="Mitglied werden"
    />
</SiteLayout>

