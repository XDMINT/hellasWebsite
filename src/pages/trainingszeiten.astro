const winterDrachenbootYoga: Session[] = [
    {
        day: "Dienstag",
        time: "18:00 – 20:00",
        title: "Drachenboot",
        group: "Erwachsene",
        location: "Kraftraum",
        contact: "C. Mauritz",
    },
    {
        day: "Donnerstag",
