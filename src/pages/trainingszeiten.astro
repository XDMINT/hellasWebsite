---
import SiteLayout from "../layouts/siteLayout.astro";
import SessionCard from "../components/SessionCard.astro";
import CtaSection from "../components/CtaSection.astro";
import { underlinedTitleClass, bodyClass, smallClass, ctaBtn, secondaryBtn } from "../lib/styles";

const sectionTitle =
    "font-albert text-2xl sm:text-3xl font-extrabold tracking-tight text-neutral-900";

/** Ganzjährig (außer Ferien/Feiertage): Hallensport */
const hall = [
    { day: "Montag", time: "16:05 – 17:00", title: "Allgemeines Hallentraining", group: "Kinder 3–6 Jahre", location: "Sandfeldschule (Sporthalle)", contact: "Fr. Körner, Fr. Moll" },
    { day: "Montag", time: "17:05 – 18:05", title: "Allgemeines Hallentraining", group: "Kinder 6–10 Jahre", location: "Sandfeldschule (Sporthalle)", contact: "Fr. Körner, Fr. Moll" },
    { day: "Montag", time: "18:10 – 19:25", title: "Allgemeines Hallentraining", group: "Jugend 10–14 Jahre", location: "Sandfeldschule (Sporthalle)", contact: "H. Weis" },
    { day: "Mittwoch", time: "20:00 – 21:30", title: "Allgemeines Hallentraining", group: "Frauen ab 18 Jahre", location: "Sandfeldschule (Sporthalle)", contact: "Fr. Heuzeroth" },
    { day: "Freitag", time: "20:00 – 21:45", title: "Allgemeines Hallentraining", group: "Männer + Frauen ab 18 Jahre", location: "Sandfeldschule (Sporthalle)", contact: "H. Weis" },
];

/** Sommer (ca. April–Oktober): Wasser + Sportabzeichen + SUP */
const summerRudern = [
    { day: "Montag", time: "17:45 – 20:00", title: "Freizeitrudern", group: "Erwachsene", location: "Vereinsgelände", contact: "M. Wiche" },
    { day: "Donnerstag", time: "17:45 – 20:00", title: "Freizeitrudern", group: "Erwachsene", location: "Vereinsgelände", contact: "M. Wiche" },
    { day: "Dienstag", time: "16:00 – 18:00", title: "Kinder + Leistungsrudern", group: "Kinder ab 8 Jahre", location: "Vereinsgelände", contact: "A. Schäfer, S. Klauke" },
    { day: "Donnerstag", time: "16:00 – 18:00", title: "Kinder + Leistungsrudern", group: "Kinder ab 8 Jahre", location: "Vereinsgelände", contact: "A. Schäfer, S. Klauke" },
    { day: "Freitag", time: "16:00 – 18:00", title: "Kinder + Leistungsrudern", group: "Kinder ab 8 Jahre", location: "Vereinsgelände", contact: "A. Schäfer, S. Klauke" },
    { day: "Samstag", time: "10:00 – 12:00", title: "Leistungsrudern", group: "Kinder ab 8 Jahre", location: "Vereinsgelände", contact: "A. Schäfer, S. Klauke" },
    { day: "Samstag", time: "14:30 – 16:30", title: "Freizeitrudern", group: "Erwachsene (Ältere)", location: "Vereinsgelände", contact: "M. Wiche", note: "Weitere Wochenend-Angebote nach Absprache möglich." },
];

const summerDrachenboot = [
    { day: "Dienstag", time: "18:00 – 20:00", title: "Drachenboot", group: "Erwachsene", location: "Vereinsgelände", contact: "C. Mauritz" },
    { day: "Donnerstag", time: "18:00 – 20:00", title: "Drachenboot", group: "Erwachsene", location: "Vereinsgelände", contact: "C. Mauritz" },
    { day: "Sonntag (jeder letzte im Monat)", time: "10:00 – 12:00", title: "Jedermann-Drachenboot", group: "Alle Interessierten", location: "Vereinsgelände", contact: "H. Weis", note: "Sommerangebot (kein Vorwissen nötig)." },
];

const summerSupSportabzeichen = [
    { day: "Dienstag", time: "18:00 – 19:30", title: "SUP", group: "Erwachsene ab 16 Jahre", location: "Vereinsgelände" },
    { day: "Freitag", time: "18:00 – 20:00", title: "Sportabzeichen-Treff", group: "Erwachsene & Kinder ab 6 Jahre", location: "Sandfeldschule / Sportanlagen", contact: "H. Weis", note: "Von den Osterferien bis zu den Herbstferien; Teilnahme auch für Nicht-Mitglieder möglich." },
];

/** Winter (ca. Oktober–April): Kraftraum + Drachenboot indoor + optional Wasser + Yoga */
const winterRudern = [
    { day: "Montag", time: "18:00 – 20:00", title: "Freizeitrudern II", group: "Erwachsene", location: "Kraftraum", contact: "M. Wiche" },
    { day: "Mittwoch", time: "15:00 – 17:00", title: "Freizeitrudern I", group: "Erwachsene (Ältere)", location: "Kraftraum", contact: "M. Wiche" },
    { day: "Donnerstag", time: "19:00 – 21:00", title: "Freizeitrudern II", group: "Erwachsene", location: "Kraftraum", contact: "M. Wiche" },
    { day: "Dienstag", time: "16:00 – 18:00", title: "Kinder + Leistungsrudern", group: "Kinder ab 8 Jahre", location: "Kraftraum", contact: "A. Schäfer, S. Klauke" },
    { day: "Donnerstag", time: "16:00 – 18:00", title: "Kinder + Leistungsrudern", group: "Kinder ab 8 Jahre", location: "Kraftraum", contact: "A. Schäfer, S. Klauke" },
    { day: "Freitag", time: "18:00 – 20:00", title: "Kinder + Leistungsrudern", group: "Kinder ab 8 Jahre", location: "Sandfeldschule (Sporthalle)", contact: "A. Schäfer, S. Klauke" },
];

const winterDrachenbootYoga = [
    { day: "Dienstag", time: "18:00 – 20:00", title: "Drachenboot", group: "Erwachsene", location: "Kraftraum", contact: "C. Mauritz" },
    { day: "Donnerstag", time: "18:00 – 20:00", title: "Drachenboot", group: "Erwachsene", location: "Kraftraum", contact: "C. Mauritz" },
    { day: "Sonntag", time: "10:00 – 12:00", title: "Drachenboot (Wasser – nach Absprache)", group: "Erwachsene", location: "Vereinsgelände", contact: "J. Schwing, Th. Hopp", note: "Im Winterhalbjahr und nach Absprache zusätzlich Training auf dem Wasser." },
    { day: "Mittwoch", time: "18:15 – 19:45", title: "Yoga (unregelmäßig)", group: "Erwachsene", location: "Sandfeldschule (Sporthalle)", contact: "K. Friese", note: "Kursangebot unregelmäßig – bitte vorher kurz nachfragen." },
];

function byDay(a, b) {
    return a.day.localeCompare(b.day, "de");
}
---

<SiteLayout
    pageTitle="Trainingszeiten | WSV Hellas Gießen - Rudern, Drachenboot & Sport"
    description="Alle Trainingszeiten des WSV Hellas Gießen: Rudern, Drachenboot, Hallensport und Sportabzeichen. Sommer- und Winterpläne für alle Altersgruppen."
    keywords="Trainingszeiten Rudern Gießen, Drachenboot Training, Hallensport Gießen, Sportabzeichen Gießen, Rudertraining Zeiten, WSV Hellas Trainingsplan"
    showHero={false}
>
    <!-- Header-Box -->
    <section class="bg-white">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
            <div class="bg-neutral-100 rounded-2xl px-6 py-10 sm:px-10 sm:py-12">
                <div class="text-center">
                    <h1 class={underlinedTitleClass}>Trainingszeiten</h1>
                    <p class={"mt-5 mx-auto max-w-3xl " + bodyClass}>
                        Hier findest du alle festen Trainingszeiten bei uns.
                        Sommer/Winter wechseln in der Regel rund um April bzw. Oktober.
                    </p>
                    <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
                        <a class={ctaBtn} href="/kontakt">Kontakt / Einstieg</a>
                        <a class={secondaryBtn} href="#ganzjaehrig">Direkt zu den Zeiten</a>
                    </div>
                    <p class={"mt-4 " + smallClass}>
                        Hinweis: Hallensport findet ganzjährig statt, aber in Schulferien/Feiertagen ist die Halle i. d. R. geschlossen.
                        Wochenend-Angebote oft nach Absprache.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section id="ganzjaehrig" class="bg-white">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12 sm:py-14">
            <div class="space-y-6">

                {/* GANZJÄHRIG */}
                <details class="group bg-neutral-100 rounded-2xl ring-1 ring-black/10 overflow-hidden" open>
                    <summary class="cursor-pointer select-none px-6 py-8 sm:px-10 sm:py-6 flex items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
                        <div>
                            <div class="font-albert text-xl sm:text-2xl font-extrabold tracking-tight text-neutral-900">Ganzjährig</div>
                            <div class="font-barlow text-sm text-neutral-600">Hallensport (Kinder/Jugend + Erwachsene) – Sandfeldschule</div>
                        </div>
                        <svg class="h-5 w-5 text-neutral-700 transition-transform duration-200 group-open:rotate-180 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" />
                        </svg>
                    </summary>

                    <div class="px-6 pt-6 pb-8 sm:px-10 sm:pt-8 sm:pb-14">
                        {/* Tabelle (sm+) */}
                        <div class="hidden sm:block overflow-x-auto">
                            <table class="w-full border-separate border-spacing-0 overflow-hidden rounded-2xl bg-white ring-1 ring-black/10">
                                <thead class="bg-neutral-50">
                                <tr class="text-left">
                                    <th class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-800">Tag</th>
                                    <th class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-800">Uhrzeit</th>
                                    <th class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-800">Angebot</th>
                                    <th class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-800">Gruppe</th>
                                    <th class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-800">Ort</th>
                                    <th class="px-4 py-3 font-barlow text-sm font-semibold text-neutral-800">Leitung</th>
                                </tr>
                                </thead>
                                <tbody class="divide-y divide-black/10">
                                {hall.slice().sort(byDay).map((s) => (
                                    <tr>
                                        <td class="px-4 py-3 font-barlow text-sm text-neutral-800">{s.day}</td>
                                        <td class="px-4 py-3 font-barlow text-sm text-neutral-800 whitespace-nowrap">{s.time}</td>
                                        <td class="px-4 py-3 font-barlow text-sm text-neutral-800">{s.title}</td>
                                        <td class="px-4 py-3 font-barlow text-sm text-neutral-700">{s.group}</td>
                                        <td class="px-4 py-3 font-barlow text-sm text-neutral-700">{s.location}</td>
                                        <td class="px-4 py-3 font-barlow text-sm text-neutral-700">{s.contact ?? "—"}</td>
                                    </tr>
                                ))}
                                </tbody>
                            </table>
                        </div>

                        {/* Mobile: SessionCard */}
                        <div class="grid gap-3 sm:hidden">
                            {hall.slice().sort(byDay).map((s) => (
                                <SessionCard {...s} />
                            ))}
                        </div>
                    </div>
                </details>

                {/* SOMMER */}
                <details class="group bg-neutral-100 rounded-2xl ring-1 ring-black/10 overflow-hidden">
                    <summary class="cursor-pointer select-none px-6 py-8 sm:px-10 sm:py-6 flex items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
                        <div>
                            <div class="font-albert text-xl sm:text-2xl font-extrabold tracking-tight text-neutral-900">Sommer</div>
                            <div class="font-barlow text-sm text-neutral-600">ca. April – Oktober · Wassertraining, SUP & Sportabzeichen</div>
                        </div>
                        <svg class="h-5 w-5 text-neutral-700 transition-transform duration-200 group-open:rotate-180 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" />
                        </svg>
                    </summary>

                    <div class="px-6 pt-6 pb-8 sm:px-10 sm:pt-8 sm:pb-14">
                        <div class="space-y-12">
                            {/* Rudern */}
                            <div>
                                <div class="h-1 w-12 rounded-full bg-blue-500/90 mb-4"></div>
                                <h3 class="font-albert text-xl sm:text-2xl font-extrabold text-neutral-900">Rudern</h3>
                                <div class="mt-5 grid gap-3">
                                    {summerRudern.map((s) => <SessionCard {...s} />)}
                                </div>
                            </div>

                            {/* Drachenboot */}
                            <div>
                                <div class="h-1 w-12 rounded-full bg-blue-500/90 mb-4"></div>
                                <h3 class="font-albert text-xl sm:text-2xl font-extrabold text-neutral-900">Drachenboot</h3>
                                <div class="mt-5 grid gap-3">
                                    {summerDrachenboot.map((s) => <SessionCard {...s} />)}
                                </div>
                            </div>

                            {/* SUP + Sportabzeichen */}
                            <div>
                                <div class="h-1 w-12 rounded-full bg-blue-500/90 mb-4"></div>
                                <h3 class="font-albert text-xl sm:text-2xl font-extrabold text-neutral-900">SUP & Sportabzeichen</h3>
                                <div class="mt-5 grid gap-3">
                                    {summerSupSportabzeichen.map((s) => <SessionCard {...s} />)}
                                </div>
                            </div>
                        </div>
                    </div>
                </details>

                {/* WINTER */}
                <details class="group bg-neutral-100 rounded-2xl ring-1 ring-black/10 overflow-hidden">
                    <summary class="cursor-pointer select-none px-6 py-8 sm:px-10 sm:py-6 flex items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
                        <div>
                            <div class="font-albert text-xl sm:text-2xl font-extrabold tracking-tight text-neutral-900">Winter</div>
                            <div class="font-barlow text-sm text-neutral-600">ca. Oktober – April · Kraftraum/Halle, Drachenboot & Yoga</div>
                        </div>
                        <svg class="h-5 w-5 text-neutral-700 transition-transform duration-200 group-open:rotate-180 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" />
                        </svg>
                    </summary>

                    <div class="px-6 pt-6 pb-8 sm:px-10 sm:pt-8 sm:pb-14">
                        <div class="space-y-12">
                            {/* Rudern */}
                            <div>
                                <div class="h-1 w-12 rounded-full bg-blue-500/90 mb-4"></div>
                                <h3 class="font-albert text-xl sm:text-2xl font-extrabold text-neutral-900">Rudern (Kraftraum / Halle)</h3>
                                <div class="mt-5 grid gap-3">
                                    {winterRudern.map((s) => <SessionCard {...s} />)}
                                </div>
                            </div>

                            {/* Drachenboot & Yoga */}
                            <div>
                                <div class="h-1 w-12 rounded-full bg-blue-500/90 mb-4"></div>
                                <h3 class="font-albert text-xl sm:text-2xl font-extrabold text-neutral-900">Drachenboot & Yoga</h3>
                                <div class="mt-5 grid gap-3">
                                    {winterDrachenbootYoga.map((s) => <SessionCard {...s} />)}
                                </div>
                            </div>
                        </div>
                    </div>
                </details>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <CtaSection
        title="Du willst einsteigen?"
        body="Schreib uns kurz, was dich interessiert (Rudern, Drachenboot, Hallensport, Sportabzeichen) – wir sagen dir, welche Gruppe am besten passt und wie der Einstieg läuft."
        primaryHref="/kontakt"
        primaryLabel="Kontakt aufnehmen"
        secondaryHref="/mitglied-werden"
        secondaryLabel="Mitglied werden"
    />
</SiteLayout>

