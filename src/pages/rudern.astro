---
// src/pages/rudern/index.astro
import SiteLayout from "../layouts/siteLayout.astro";
import SectionIntro from "../components/SectionIntro.astro";
import CtaSection from "../components/CtaSection.astro";
import SportCard from "../components/SportCard.astro";
import RuderAmpel from "../components/ruderampel.astro";
import { rudernDoppelzweier, rudernBreitSport, rudernKind, rudernPodium } from "../assets/images";
import { ctaBtn, secondaryBtn, bodyClass } from "../lib/styles";
---

<SiteLayout
        pageTitle="Rudern in Gießen | WSV Hellas - Breitensport & Wettkampf"
        description="Rudern auf der Lahn beim WSV Hellas Gießen. Für Anfänger, Breitensportler und Wettkampf-Ruderer. Ruderkurse, Schnupperrudern und Training für alle Altersgruppen."
        keywords="Rudern Gießen, Ruderkurse Gießen, Rudern lernen, Breitensportrudern, Wettkampfrudern, Rudern Lahn, Rudertraining, Rudern Anfänger, Schnupperrudern Gießen, Leistungssport Rudern, Ruderverein Gießen, WSV Hellas Rudern"
        heroTitle="Rudern"
        heroSubtitle="Gemeinsam auf der Lahn – vom ersten Schlag bis zur Regatta"
        heroImage={rudernDoppelzweier}
        showHero={true}
        heroImageCredit="© Frank Beck"
>
    <RuderAmpel slot="heroTopLeft" variant="overlay" />

    <div id="top" class="sr-only">Top</div>

    <!-- Intro -->
    <SectionIntro title="Rudern an der Hellas">
        <p class={bodyClass}>
            Rudern verbindet Ausdauer, Technik und Teamgeist und ist dabei erstaunlich vielseitig:
            entspanntes Rudern nach Feierabend, strukturiertes Training im Boot oder ambitionierte Rennen.
            Bei uns findest du den Einstieg, passende Trainingsgruppen und eine starke Gemeinschaft. Direkt
            auf der Lahn in Gießen.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
            <a class={ctaBtn} href="/trainingszeiten">Trainingszeiten ansehen</a>
            <a class={secondaryBtn} href="/kontakt">Kontakt & Probetraining</a>
        </div>

        <p class="mt-4 font-barlow text-sm text-neutral-600">
            Hinweis: Für Kinder ist ein sicherer Schwimmnachweis erforderlich.
        </p>
    </SectionIntro>

    <!-- 3 Bereiche als Cards -->
    <section class="bg-white">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-12 sm:pb-14">
            <div class="grid gap-6 lg:grid-cols-3">
                <SportCard
                    src={rudernBreitSport}
                    alt="Breitensport Rudern"
                    credit="© No4Any"
                    kicker="Für Einsteiger & Fortgeschrittene"
                    title="Breitensport"
                    body="Du willst dich bewegen, den Kopf frei bekommen und dabei in netter Runde aufs Wasser? Im Breitensport steht das gemeinsame Rudern im Vordergrund – mit viel Spaß und ohne Leistungsdruck."
                    bullets={["lockere Einheiten auf der Lahn", "Technik-Tipps & sicheres Bootshandling", "Gemeinschaft, Ausgleich, Natur"]}
                />

                <SportCard
                    src={rudernKind}
                    alt="Kinder & Jugendliche Rudern"
                    credit="© Privat"
                    kicker="Ab ca. 12 Jahren"
                    title="Kinder & Jugendliche"
                    body="Spielerisch lernen, draußen aktiv sein und Schritt für Schritt Sicherheit im Boot bekommen: Im Nachwuchsbereich bauen wir Grundlagen auf – von Balance bis Technik – und fördern Teamgeist und Selbstvertrauen."
                    bullets={["Altersgerechtes Training & Betreuung", "Technik, Koordination, Spaß am Wasser", "Optional: erste Regatta-Erfahrungen"]}
                />

                <SportCard
                    src={rudernPodium}
                    alt="Rennrudern"
                    credit="© Sonja Liese"
                    kicker="Strukturiert & leistungsorientiert"
                    title="Rennrudern"
                    body="Du hast Lust, dich sportlich weiterzuentwickeln, an Regatten teilzunehmen und im Team an Geschwindigkeit zu arbeiten? Im Rennrudern kombinieren wir Technik, Ausdauer und Kraft – mit klaren Zielen und viel Zusammenhalt."
                    bullets={["Technik- und Temposchulung", "Mannschaftsboote & Regatten", "Athletiktraining als Ergänzung"]}
                />
            </div>
        </div>
    </section>

    <!-- CTA -->
    <CtaSection
        title="Lust auf ein Probetraining?"
        body="Egal ob du neu startest oder schon Erfahrung mitbringst: Schreib uns kurz – wir finden die passende Gruppe. Die aktuellen Zeiten und Treffpunkte findest du auf der Trainingszeiten-Seite."
        primaryHref="/kontakt"
        primaryLabel="Jetzt anfragen"
        secondaryHref="/mitglied-werden"
        secondaryLabel="Mitglied werden"
    />
</SiteLayout>
