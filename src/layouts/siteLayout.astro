---
// src/layouts/SiteLayout.astro
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";
import CookieConsent from "../components/cookieConsent.astro";
import OptimizedImg from "../components/OptimizedImg.astro";
import { Image } from "astro:assets";
import "../styles/global.css"
import type { ImageMetadata } from "astro";

type Props = {
	pageTitle?: string;
	description?: string;
	keywords?: string;
	heroTitle?: string;
	heroSubtitle?: string;
	heroImage?: string | ImageMetadata;
	heroImages?: (string | ImageMetadata)[];
	heroImageCredit?: string;
	heroImageCredits?: (string | undefined)[];
	showHero?: boolean;
	ogType?: string;
	canonicalURL?: string;
};

const {
	pageTitle = "WSV Hellas 1920 Gießen e. V.",
	description = "WSV Hellas 1920 Gießen e.V. - Wassersportverein für Rudern, Drachenboot und allgemeinen Sport auf der Lahn. Familiärer Verein mit über 100 Jahren Tradition.",
	keywords = "Rudern Gießen, Drachenboot Gießen, Wassersport Lahn, WSV Hellas, Ruderverein Gießen, Ruderkurse, Breitensport, Wettkampfrudern",
	heroTitle = "Wassersportverein Hellas Gießen",
	heroSubtitle,
	heroImage = "/images/header-default.jpg",
	heroImages = ["/images/home-1.jpg", "/images/home-2.jpg", "/images/home-3.jpg"],
	heroImageCredit,
	heroImageCredits,
	showHero = true,
	ogType = "website",
	canonicalURL
} = Astro.props as Props;

const siteURL = "https://wsv-hellas.de";
const currentURL = canonicalURL || new URL(Astro.url.pathname, siteURL).href;
const ogImagePath = typeof heroImage === 'string' ? heroImage : heroImage.src;

const normalize = (p: string) => (p.length > 1 && p.endsWith("/") ? p.slice(0, -1) : p);
const pathname = normalize(Astro.url?.pathname ?? "/");
const isHome = pathname === "/";

const useSlideshow = isHome && heroImages.length > 1;
---

<!doctype html>
<html lang="de">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />

	<!-- Font Preloads: kritische Schriften früh laden, damit sie nicht den Render blockieren -->
	<link rel="preload" href="/fonts/Albert_Sans/AlbertSans-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
	<link rel="preload" href="/fonts/Barlow/Barlow-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

	<!-- Favicons -->
	<link rel="icon" type="image/jpg" href="/hellasLogoNeu.jpg" />
	<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
	<link rel="manifest" href="/site.webmanifest" />

	<!-- Primary Meta Tags -->
	<title>{pageTitle}</title>
	<meta name="title" content={pageTitle} />
	<meta name="description" content={description} />
	<meta name="keywords" content={keywords} />
	<meta name="author" content="WSV Hellas 1920 Gießen e.V." />
	<meta name="robots" content="index, follow" />
	<link rel="canonical" href={currentURL} />

	<!-- Open Graph / Facebook -->
	<meta property="og:type" content={ogType} />
	<meta property="og:url" content={currentURL} />
	<meta property="og:title" content={pageTitle} />
	<meta property="og:description" content={description} />
	<meta property="og:image" content={siteURL + ogImagePath} />
	<meta property="og:site_name" content="WSV Hellas Gießen" />
	<meta property="og:locale" content="de_DE" />

	<!-- Twitter -->
	<meta property="twitter:card" content="summary_large_image" />
	<meta property="twitter:url" content={currentURL} />
	<meta property="twitter:title" content={pageTitle} />
	<meta property="twitter:description" content={description} />
	<meta property="twitter:image" content={siteURL + ogImagePath} />

	<!-- Geo Tags für lokale SEO -->
	<meta name="geo.region" content="DE-HE" />
	<meta name="geo.placename" content="Gießen" />
	<meta name="geo.position" content="50.585;8.678" />
	<meta name="ICBM" content="50.585, 8.678" />

	<!-- Structured Data (JSON-LD) -->
	<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "SportsOrganization",
			"name": "WSV Hellas 1920 Gießen e.V.",
			"alternateName": "Wassersportverein Hellas Gießen",
			"url": "https://wsv-hellas.de",
			"logo": "https://wsv-hellas.de/images/220926_HellasGiessen-Logo-Web.png",
			"description": "Wassersportverein in Gießen für Rudern, Drachenboot und allgemeinen Sport",
			"foundingDate": "1920-09",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Wißmarer Weg 125",
				"addressLocality": "Gießen",
				"postalCode": "35396",
				"addressCountry": "DE"
			},
			"geo": {
				"@type": "GeoCoordinates",
				"latitude": "50.585",
				"longitude": "8.678"
			},
			"sport": ["Rowing", "Dragon Boat", "Water Sports"],
			"sameAs": [
				"https://www.facebook.com/wsvhellas"
			]
		}
	</script>

	<meta name="google-site-verification" content="PyfTqezbyUGstpbp_XMb4cJ_shDpep2Kqe60RcLxzzI" />

	<!-- Umami Analytics -->
	<script defer src="https://cloud.umami.is/script.js" data-website-id="df4ccfdb-3d93-48ae-bf06-156d866a6bb5"></script>
</head>

<body class="min-h-screen flex flex-col font-body text-neutral-900 bg-white">
<Header />

{showHero && (
	<section class="relative w-full">
		{/* Hero-Höhe (responsive) */}
		<div class="relative w-full h-80 sm:h-140 overflow-hidden">
			<div class="absolute top-4 left-4 sm:top-6 sm:left-6 z-20">
				<slot name="heroTopLeft" />
			</div>
		{useSlideshow ? (
			<div class="absolute inset-0" id="hero-slideshow">
				{(heroImages as any[]).map((img, idx) => (
					<div
						class:list={[
							"absolute inset-0 transition-opacity duration-700",
							idx === 0 ? "opacity-100" : "opacity-0",
						]}
						data-slide
					>
						{typeof img === 'string' ? (
							<img
								src={img}
								alt=""
								loading={idx === 0 ? "eager" : "lazy"}
								decoding="async"
								fetchpriority={idx === 0 ? "high" : "auto"}
								class="absolute inset-0 h-full w-full object-cover"
							/>
						) : (
							<Image
								src={img}
								alt=""
								class="absolute inset-0 h-full w-full object-cover"
								loading={idx === 0 ? "eager" : "lazy"}
								fetchpriority={idx === 0 ? "high" : "auto"}
								widths={[640, 960, 1280, 1920]}
								sizes="100vw"
							/>
						)}
						{heroImageCredits?.[idx] && (
							<div class="absolute bottom-2 right-2 rounded bg-black/60 px-2 py-0.5 font-barlow text-[10px] text-white" style="z-index: 2;">
								{heroImageCredits[idx]}
							</div>
						)}
					</div>
				))}
			</div>
		) : (
			typeof heroImage === 'string' ? (
				<img
					src={heroImage}
					alt=""
					loading="eager"
					decoding="async"
					fetchpriority="high"
					class="absolute inset-0 h-full w-full object-cover"
				/>
			) : (
				<Image
					src={heroImage}
					alt=""
					class="absolute inset-0 h-full w-full object-cover"
					loading="eager"
					decoding="async"
					fetchpriority="high"
					widths={[640, 960, 1280, 1920]}
					sizes="100vw"
				/>
			)
		)}

			{!useSlideshow && (heroImageCredit || heroImageCredits?.[0]) && (
				<div class="absolute bottom-2 right-2 rounded bg-black/60 px-2 py-0.5 font-barlow text-[10px] text-white" style="z-index: 2;">
					{heroImageCredit || heroImageCredits?.[0]}
				</div>
			)}

			{/* Text sitzt unten im Bild (statt mittig) */}
			<div class="absolute inset-0 flex items-end justify-center px-4 sm:px-6 lg:px-8 pb-10 sm:pb-12 lg:pb-14">
				<div class="text-center max-w-5xl">
					<h1 class="text-white tracking-tight text-3xl sm:text-4xl lg:text-5xl font-albert font-extrabold hero-shadow">
						{heroTitle}
					</h1>

					{heroSubtitle && (
						<h2 class="mt-3 text-white text-base sm:text-3xl font-albert font-bold hero-shadow-strong">
							{heroSubtitle}
						</h2>
					)}
				</div>
			</div>
		</div>
	</section>
)}

<main class="flex-1">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
		<slot />
	</div>
</main>

<Footer />

{useSlideshow && (
	<script is:inline>
		(() => {
			const root = document.getElementById("hero-slideshow");
			if (!root) return;

			const slides = Array.from(root.querySelectorAll("[data-slide]"));
			if (slides.length <= 1) return;

			let i = 0;
			setInterval(() => {
				slides[i].classList.remove("opacity-100");
				slides[i].classList.add("opacity-0");
				i = (i + 1) % slides.length;
				slides[i].classList.remove("opacity-0");
				slides[i].classList.add("opacity-100");
			}, 5000);
		})();
		</script>
)}

<CookieConsent />
</body>
</html>

