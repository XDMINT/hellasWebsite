---
/**
 * NewsCard – Grid-Karte für News-Beiträge (news/index.astro)
 *
 * Props:
 *   href     – Link zur News-Detailseite
 *   imgSrc   – URL des Vorschaubilds (optional, aus WP)
 *   date     – Formatiertes Datum (z. B. "12. März 2026")
 *   title    – Beitrags-Titel
 *   excerpt  – Kurzbeschreibung (bereits HTML-stripped)
 */
import OptimizedImg from "./OptimizedImg.astro";

interface Props {
  href: string;
  imgSrc?: string | null;
  date: string;
  title: string;
  excerpt: string;
}

const { href, imgSrc, date, title, excerpt } = Astro.props;
---

<a
  href={href}
  data-astro-prefetch
  class="group rounded-2xl overflow-hidden bg-white ring-1 ring-neutral-200 shadow-sm
         transition duration-200 ease-out hover:bg-blue-600 hover:shadow-md hover:-translate-y-0.5"
>
  <div class="relative aspect-[16/9] bg-neutral-200">
    {imgSrc ? (
      <OptimizedImg
        src={imgSrc}
        alt="News Post"
        className="absolute inset-0 h-full w-full"
        loading="lazy"
      />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-neutral-200 to-neutral-300" />
    )}
    <div class="absolute left-4 bottom-4 h-1 w-16 rounded-full bg-blue-500/90 group-hover:bg-white/80 transition-colors"></div>
  </div>

  <div class="p-5">
    <div class="font-barlow text-xs text-neutral-500 group-hover:text-white/80 transition-colors">
      {date}
    </div>

    <h3 class="mt-2 font-albert text-lg font-extrabold tracking-tight text-neutral-900 group-hover:text-white transition-colors">
      {title}
    </h3>

    <p class="mt-2 font-barlow text-sm text-neutral-700 group-hover:text-white/90 transition-colors line-clamp-3">
      {excerpt}
    </p>

    <div class="mt-4 font-barlow text-sm font-semibold text-blue-600 group-hover:text-white/90 transition-colors">
      <span class="inline-flex items-center gap-2 transition-transform duration-200 group-hover:translate-x-1">
        Weiterlesen <span aria-hidden="true">→</span>
      </span>
    </div>
  </div>
</a>

