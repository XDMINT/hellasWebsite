---
/**
 * SportCard – Bild-Karte für Sport-Bereiche (rudern.astro)
 *
 * Props:
 *   src       – Bild-Import (ImageMetadata)
 *   alt       – Bild-Alt-Text
 *   credit    – Foto-Credit-Text (optional)
 *   kicker    – Kleiner Kategorietext über dem Titel
 *   title     – Kartenüberschrift
 *   body      – Beschreibungstext
 *   bullets   – Liste von Bullet-Punkten (ohne "•", wird automatisch ergänzt)
 *   widths    – Bildbreiten für Optimierung (optional)
 *   sizes     – sizes-Attribut (optional)
 */
import OptimizedImg from "./OptimizedImg.astro";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  credit?: string;
  kicker: string;
  title: string;
  body: string;
  bullets: string[];
  widths?: number[];
  sizes?: string;
}

const {
  src,
  alt,
  credit,
  kicker,
  title,
  body,
  bullets,
  widths = [400, 640, 800],
  sizes = "(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw",
} = Astro.props;
---

<article
  class="group overflow-hidden rounded-2xl bg-white ring-1 ring-black/10 shadow-sm
         transition duration-200 ease-out hover:bg-blue-600 hover:shadow-md hover:-translate-y-0.5"
>
  <div class="relative aspect-[16/9] bg-neutral-200">
    <OptimizedImg
      src={src}
      alt={alt}
      className="absolute inset-0 h-full w-full"
      loading="lazy"
      credit={credit}
      widths={widths}
      sizes={sizes}
    />
    <div class="absolute left-4 bottom-4 h-1 w-16 rounded-full bg-blue-500/90 group-hover:bg-white/80 transition-colors"></div>
  </div>

  <div class="p-6">
    <div class="font-barlow text-sm font-semibold text-blue-700 group-hover:text-white/80 transition-colors">
      {kicker}
    </div>

    <h3 class="mt-2 font-albert text-2xl sm:text-3xl font-extrabold tracking-tight text-neutral-900 group-hover:text-white transition-colors">
      {title}
    </h3>

    <p class="mt-3 font-barlow text-sm sm:text-base leading-relaxed text-neutral-700 group-hover:text-white/90 transition-colors">
      {body}
    </p>

    <ul class="mt-4 space-y-2">
      {bullets.map((b) => (
        <li class="font-barlow text-sm sm:text-base text-neutral-700 group-hover:text-white/90 transition-colors">
          • {b}
        </li>
      ))}
    </ul>
  </div>
</article>

