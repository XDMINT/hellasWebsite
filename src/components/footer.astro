---
// src/components/Footer.astro
const year = new Date().getFullYear();

type Props = {
    clubName?: string;
    tagline?: string;
    addressLines?: string[];
    email?: string;
    phone?: string;
    links?: { label: string; href: string }[];
    socials?: { label: string; href: string }[];
};

const {
    clubName = "WSV Hellas 1920 Gießen e. V.",
    tagline = "„Auf dem Wasser zuhause“",
    addressLines = ["Wißmarer Weg 125", "35396 Gießen", "Deutschland"],
    email = "info@wsv-hellas.de",
    phone = "",
    links = [
        { label: "News", href: "/news" },
        { label: "Rudern", href: "/rudern" },
        { label: "Drachenboot", href: "/drachenboot" },
        { label: "Vorstand", href: "/vorstand" },
    ],
    socials = [
        { label: "Instagram", href: "https://www.instagram.com/wsvhellas_giessen?igsh=bzRhNGNwY3RxZ2dk" },
        { label: "Facebook", href: "https://www.facebook.com/WSVHellas" },
    ],
} = Astro.props as Props;
---

<footer class="bg-neutral-900 text-neutral-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Brand -->
            <div class="space-y-3">
                <div class="font-albert text-lg font-extrabold tracking-tight">
                    {clubName}
                </div>
                <div class="font-barlow text-sm text-neutral-300">
                    {tagline}
                </div>

                <div class="pt-2 font-barlow text-sm text-neutral-300 space-y-1">
                    {addressLines.map((line) => <div>{line}</div>)}
                </div>
            </div>

            <!-- Kontakt -->
            <div class="space-y-3">
                <div class="font-albert text-sm font-bold uppercase tracking-wider text-neutral-200">
                    Kontakt
                </div>

                <ul class="font-barlow space-y-2 text-sm text-neutral-300">
                    <li>
                        <a
                                class="inline-flex items-center gap-2 hover:text-white transition"
                                href={`mailto:${email}`}
                        >
                            <span class="opacity-80">✉</span>
                            <span>{email}</span>
                        </a>
                    </li>

                    {phone && (
                            <li>
                                <a
                                        class="inline-flex items-center gap-2 hover:text-white transition"
                                        href={`tel:${phone.replace(/\s+/g, "")}`}
                                >
                                    <span class="opacity-80">☎</span>
                                    <span>{phone}</span>
                                </a>
                            </li>
                    )}
                </ul>

                <div class="font-barlow text-xs text-neutral-400 leading-relaxed">
                    Trainingszeiten & Ansprechpartner findest du in den jeweiligen Sparten.
                </div>
            </div>

            <!-- Links -->
            <div class="space-y-3">
                <div class="font-albert text-sm font-bold uppercase tracking-wider text-neutral-200">
                    Navigation
                </div>
                <ul class="font-barlow space-y-2 text-sm">
                    {links.map((l) => (
                            <li>
                                <a
                                        href={l.href}
                                        class="text-neutral-300 hover:text-white transition relative inline-block
                       after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-1
                       after:h-px after:bg-white/0 hover:after:bg-white/40 after:transition"
                                >
                                    {l.label}
                                </a>
                            </li>
                    ))}
                </ul>
            </div>

            <!-- Social / Rechtliches -->
            <div class="space-y-3">
                <div class="font-albert text-sm font-bold uppercase tracking-wider text-neutral-200">
                    Mehr
                </div>

                {socials?.length ? (
                        <div class="flex flex-wrap gap-2">
                            {socials.map((s) => (
                                    <a
                                            href={s.href}
                                            target="_blank"
                                            rel="noreferrer"
                                            class="font-barlow px-3 py-1.5 rounded-full text-sm
                       bg-white/5 text-neutral-200 hover:bg-white/10 hover:text-white transition"
                                    >
                                        {s.label}
                                    </a>
                            ))}
                        </div>
                ) : null}

                <div class="pt-2 flex flex-col gap-2 text-sm font-barlow">
                    <a class="text-neutral-300 hover:text-white transition" href="/impressum">Impressum</a>
                    <a class="text-neutral-300 hover:text-white transition" href="/datenschutz">Datenschutz</a>
                </div>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="mt-10 pt-6 border-t border-white/10 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div class="font-barlow text-xs text-neutral-400">
                © {year} {clubName}. Alle Rechte vorbehalten.
            </div>

            <a
                    href="#top"
                    class="font-barlow text-xs text-neutral-300 hover:text-white transition inline-flex items-center gap-2"
            >
                Nach oben <span aria-hidden="true">↑</span>
            </a>
        </div>
    </div>
</footer>

