---
type Props = { class?: string; variant?: "default" | "overlay"; };
const { class: className = "", variant = "default" } = Astro.props as Props;
const isOverlay = variant === "overlay";
---

<div class:list={["w-fit", className]} data-ampel-root data-is-overlay={isOverlay ? "true" : "false"}>
    <button type="button" class:list={["group inline-flex items-center justify-center rounded-2xl transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300 relative z-30 pointer-events-auto cursor-pointer", isOverlay ? "w-12 h-12 sm:w-14 sm:h-14 bg-transparent" : "w-12 h-12 sm:w-14 sm:h-14 bg-neutral-100 ring-1 ring-black/10 shadow-sm hover:shadow-md hover:bg-neutral-50", isOverlay ? "flex-col gap-1.5" : "flex-row"]} aria-label="Ruderampel öffnen" aria-haspopup="dialog" aria-expanded="false" data-ampel-toggle data-ampel-button>
         <span class="sr-only">Wassersportampel</span>
         {isOverlay ? (
             <span class="flex flex-col items-center gap-1.5 rounded-lg bg-neutral-900/90 p-2 ring-1 ring-black/40 shadow-inner transition group-hover:shadow-md group-hover:shadow-black/40">
                 <span class="block h-3 w-3 rounded-full bg-neutral-400/50" data-ampel-mini-light="red"></span>
                 <span class="block h-3 w-3 rounded-full bg-neutral-400/50" data-ampel-mini-light="yellow"></span>
                 <span class="block h-3 w-3 rounded-full bg-neutral-400/50" data-ampel-mini-light="green"></span>
             </span>
         ) : (
             <span class:list={["block rounded-full animate-pulse", "w-7 h-7", "bg-neutral-300"]} data-ampel-dot></span>
         )}
         {isOverlay ? (
            <span class="px-2 py-0.5 rounded-full text-[10px] font-barlow font-semibold bg-white/90 text-neutral-800 ring-1 ring-black/10 shadow-sm">Öffnen</span>
        ) : (
            <span class="ml-2 text-xs font-barlow text-neutral-600 hidden sm:inline">Öffnen</span>
        )}
     </button>

    <div id="ampel-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4" style="z-index: 9999999" data-ampel-modal>
         <div class="bg-white rounded-2xl shadow-2xl max-w-5xl w-full max-h-[90vh] overflow-y-auto" role="dialog">
             <div class="sticky top-0 bg-white border-b border-neutral-200 px-6 py-4 flex items-center justify-between rounded-t-2xl" style="z-index: 1000;">
                 <div class="flex items-center gap-4">
                     <div class="shrink-0 rounded-xl bg-neutral-900 p-2 shadow-inner">
                         <div class="flex flex-col gap-1.5">
                             <span class="block rounded-full w-5 h-5 bg-neutral-500/40" data-light="red"></span>
                             <span class="block rounded-full w-5 h-5 bg-neutral-500/40" data-light="yellow"></span>
                             <span class="block rounded-full w-5 h-5 bg-neutral-500/40" data-light="green"></span>
                         </div>
                     </div>
                     <div>
                         <h2 class="font-albert text-xl font-extrabold text-neutral-900">Wassersportampel</h2>
                         <p class="font-barlow text-sm text-neutral-600">Lahn-Pegel-Leun</p>
                     </div>
                 </div>
                 <button type="button" class="rounded-xl px-4 py-2 font-barlow text-sm font-semibold bg-neutral-100 hover:bg-neutral-200 ring-1 ring-black/10 transition" data-ampel-close>✕ Schließen</button>
             </div>

            <div class="p-6 space-y-6">
                <div class="rounded-xl p-4 ring-1" data-status-alert>
                    <div class="flex items-start gap-3">
                        <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center" data-status-icon><span class="text-2xl">●</span></div>
                        <div class="flex-1">
                            <div class="font-albert text-lg font-bold" data-status-title>Status wird geladen...</div>
                            <div class="font-barlow text-sm mt-1" data-hint>Daten werden abgerufen...</div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                    <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                        <div class="font-barlow text-xs text-neutral-500 uppercase tracking-wide">Pegelstand</div>
                        <div class="font-albert text-2xl font-bold text-neutral-900 mt-1" data-level>–</div>
                        <div class="font-barlow text-xs text-neutral-600 mt-1" data-trend>–</div>
                    </div>
                    <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                        <div class="font-barlow text-xs text-neutral-500 uppercase tracking-wide">Wassertemp.</div>
                        <div class="font-albert text-2xl font-bold text-neutral-900 mt-1" data-temp>–</div>
                    </div>
                    <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                        <div class="font-barlow text-xs text-neutral-500 uppercase tracking-wide">Lufttemp.</div>
                        <div class="font-albert text-2xl font-bold text-neutral-900 mt-1" data-air-temp>–</div>
                        <div class="font-barlow text-xs text-neutral-500 mt-1"></div>
                    </div>
                    <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                        <div class="font-barlow text-xs text-neutral-500 uppercase tracking-wide">Wetter</div>
                        <div class="font-barlow text-sm text-neutral-900 mt-1" data-weather>–</div>
                    </div>
                </div>

                <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                    <h3 class="font-albert text-base font-bold text-neutral-900 mb-3">Pegelverlauf & Prognose (48h)</h3>
                    <div class="relative h-80 bg-white rounded-lg p-3"><canvas id="water-chart"></canvas></div>
                    <div class="mt-2 font-barlow text-xs text-neutral-600">
                        <span class="inline-block mr-4">🔵 Historische Daten (24h)</span>
                        <span class="inline-block mr-4">🟠 Prognose (24h)</span>
                        <span class="inline-block">🔴 Hochwasser (360 cm)</span>
                    </div>
                    <div class="mt-1 font-barlow text-xs text-neutral-500">
                        Quelle: Pegelonline WSV (Pegelstände)
                    </div>
                </div>

                <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                    <h3 class="font-albert text-base font-bold text-neutral-900 mb-3">Pegel-Prognose (nächste 24h)</h3>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" data-water-forecast>
                        <div class="text-center bg-white rounded-lg p-3">
                            <div class="font-barlow text-xs text-neutral-500">Lade...</div>
                        </div>
                    </div>
                    <div class="mt-2 font-barlow text-xs text-neutral-600">
                        Prognose basierend auf aktuellem Trend und Niederschlagsvorhersage
                    </div>
                    <div class="mt-1 font-barlow text-xs text-neutral-500">
                        Quelle: Pegelonline WSV + Open-Meteo (Niederschlag)
                    </div>
                    <div class="mt-2">
                        <a href="https://www.hochwasser.rlp.de/flussgebiet/lahn/leun" target="_blank" rel="noopener" class="font-barlow text-xs text-blue-600 hover:text-blue-800 underline">
                            Offizielle Hochwasservorhersage RLP für Leun
                        </a>
                    </div>
                </div>

                <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                    <h3 class="font-albert text-base font-bold text-neutral-900 mb-3">Wettervorhersage Gießen</h3>
                    <div class="flex flex-wrap gap-2 mb-3" data-forecast-controls>
                        <button type="button" class="px-3 py-1.5 rounded-lg text-xs font-barlow font-semibold bg-blue-600 text-white" data-forecast-range="2h">2h</button>
                        <button type="button" class="px-3 py-1.5 rounded-lg text-xs font-barlow font-semibold bg-neutral-200 text-neutral-800" data-forecast-range="6h">6h</button>
                        <button type="button" class="px-3 py-1.5 rounded-lg text-xs font-barlow font-semibold bg-neutral-200 text-neutral-800" data-forecast-range="12h">12h</button>
                        <button type="button" class="px-3 py-1.5 rounded-lg text-xs font-barlow font-semibold bg-neutral-200 text-neutral-800" data-forecast-range="48h">2 Tage</button>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" data-forecast></div>
                    <div class="mt-2 font-barlow text-xs text-neutral-500">
                        Quelle: Open-Meteo (Gießen)
                    </div>
                </div>

                <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4" data-radar-section>
                    <h3 class="font-albert text-base font-bold text-neutral-900 mb-3">🌧️ Regenradar</h3>

                    <!-- isolation:isolate verhindert dass Leaflet-Buttons aus dem Container herausragen -->
                    <div class="rounded-lg overflow-hidden" style="height: 400px; position: relative; isolation: isolate;">
                        <div id="radar-map" class="w-full h-full"></div>
                        <div class="absolute bottom-2 left-2 bg-white/95 rounded-lg px-3 py-2 shadow-md font-barlow text-xs" style="z-index: 10; pointer-events: none;">
                            <span data-radar-timestamp>Lade Radar...</span>
                        </div>
                    </div>

                    <div class="mt-3 flex items-center gap-3">
                        <button type="button" class="shrink-0 w-10 h-10 rounded-lg bg-blue-600 text-white flex items-center justify-center hover:bg-blue-700 transition shadow-sm" data-radar-toggle aria-label="Animation starten/stoppen">
                            <span class="text-base" data-radar-icon>▶</span>
                        </button>

                        <div class="flex-1">
                            <!-- Aktuelle Frame-Zeit über dem Fortschrittsbalken -->
                            <div class="mb-1.5 font-barlow text-xs font-semibold text-neutral-700 text-center" data-radar-current-time>–</div>
                            <div class="relative bg-neutral-200 rounded-full h-3 mb-1.5">
                                <div class="absolute top-0 left-0 h-full bg-blue-600 rounded-full transition-all duration-300" style="width: 0%;" data-radar-progress></div>
                                <div class="absolute top-0 left-0 h-full bg-yellow-400 rounded-full transition-all duration-300" style="width: 0%;" data-radar-progress-forecast></div>
                            </div>
                            <div class="relative font-barlow text-[10px] text-neutral-500 px-1 mt-1" style="min-height: 28px;" data-radar-timeline></div>
                        </div>
                    </div>

                    <div class="mt-2 font-barlow text-xs text-neutral-500">
                        Quelle: Bright Sky / DWD (Deutscher Wetterdienst)
                    </div>
                </div>


                 <div class="rounded-xl bg-blue-50 ring-1 ring-blue-200 p-4">
                    <h3 class="font-albert text-base font-bold text-blue-900 mb-2">📋 Ruderregeln</h3>
                    <ul class="font-barlow text-sm text-blue-900 space-y-1">
                        <li>🔴 <strong>Rot:</strong> Wassersportverbot (Hochwasser &gt;360cm oder &lt;1°C)</li>
                        <li>🟡 <strong>Gelb:</strong> Eingeschränkter Betrieb (Kaltwasser 1-10°C)</li>
                        <li>🟢 <strong>Grün:</strong> Normaler Betrieb</li>
                    </ul>
                </div>

                <div class="text-center font-barlow text-xs text-neutral-500">Letzte Aktualisierung: <span data-time>–</span></div>
            </div>
        </div>
    </div>

    <script>
        // Modal in document.body verschieben (Portal) – unabhängig von Stacking Contexts
        (function portalModal() {
            const doPortal = () => {
                const modal = document.getElementById("ampel-modal");
                if (modal && modal.parentElement !== document.body) {
                    document.body.appendChild(modal);
                }
            };
            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", doPortal);
            } else {
                doPortal();
            }
        })();
    </script>

    <script>
        import { initBrightSkyRadar } from "../lib/brightsky-radar";

        const radarModal = document.querySelector("[data-ampel-modal]");
        if (radarModal) {
            let radarInitialized = false;
            new MutationObserver(async () => {
                if (!radarModal.classList.contains("hidden") && !radarInitialized) {
                    radarInitialized = true;
                    await initBrightSkyRadar("radar-map");
                }
            }).observe(radarModal, { attributes: true, attributeFilter: ["class"] });
        }
    </script>

    <script>
        import { initRuderampel } from "../lib/ruderampel-core";

        // isOverlay wird via data-Attribut übergeben, damit kein is:inline nötig ist
        const root = document.querySelector<HTMLElement>("[data-ampel-root]");
        const isOverlay = root?.dataset.isOverlay === "true";
        initRuderampel(isOverlay);
    </script>
</div>
