---
type Props = {
    class?: string;
    /** "default" = normal, "overlay" = dezente Hero-Overlay-Variante */
    variant?: "default" | "overlay";
};

const { class: className = "", variant = "default" } = Astro.props as Props;

const isOverlay = variant === "overlay";
---

<div class:list={["w-fit", className]} data-ampel-root>
    <!-- Collapsed: nur das aktive Licht (dezent) -->
    <button
            type="button"
            class:list={[
                "group inline-flex items-center justify-center rounded-2xl transition",
                "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300",
                isOverlay
                    ? "w-9 h-9 sm:w-10 sm:h-10 bg-transparent ring-1 ring-black/10 hover:ring-black/20 hover:bg-white/10"
                    : "w-12 h-12 sm:w-14 sm:h-14 bg-neutral-100 ring-1 ring-black/10 shadow-sm hover:shadow-md hover:bg-neutral-50",
            ]}
            aria-label="Ruderampel anzeigen"
            aria-expanded="false"
            aria-controls="ruderampel-panel"
            data-ampel-toggle
    >
        <span class="sr-only">Ruderampel</span>

        <span
                class:list={[
                    "block rounded-full",
                    isOverlay ? "w-5 h-5 sm:w-5.5 sm:h-5.5" : "w-6 h-6 sm:w-7 sm:h-7",
                    "bg-neutral-300 animate-pulse",
                ]}
                data-ampel-dot
        ></span>
    </button>

    <!-- Expanded Panel -->
    <div
            id="ruderampel-panel"
            class:list={[
                "hidden mt-2 rounded-2xl ring-1 ring-black/10 shadow-md",
                // transparent + blur im Overlay, normal etwas "fester"
      isOverlay ? "bg-white/70 backdrop-blur-md" : "bg-neutral-100",
                // Größe im Overlay etwas kompakter
      isOverlay ? "p-3 sm:p-4 w-[min(92vw,460px)]" : "p-4 sm:p-5 w-[min(92vw,520px)]",
            ]}
            data-ampel-panel
            aria-hidden="true"
    >
        <div class="flex items-start gap-3">
            <!-- Ampel-Gehäuse (3 Lichter) -->
            <div
                    class:list={[
                        "shrink-0 rounded-2xl p-3 shadow-inner",
                        isOverlay ? "bg-neutral-900/70" : "bg-neutral-900/90",
                    ]}
            >
                <div class="flex flex-col gap-2">
                    <span class="block rounded-full w-7 h-7 bg-neutral-500/40" data-light="red"></span>
                    <span class="block rounded-full w-7 h-7 bg-neutral-500/40" data-light="yellow"></span>
                    <span class="block rounded-full w-7 h-7 bg-neutral-500/40" data-light="green"></span>
                </div>
            </div>

            <!-- Details -->
            <div class="min-w-0 flex-1">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <div class="font-albert text-base sm:text-lg text-neutral-900">Ruderampel</div>
                        <div class="font-barlow text-xs sm:text-sm text-neutral-600" data-station>Leun (Lahn)</div>
                    </div>

                    <button
                            type="button"
                            class:list={[
                                "rounded-xl px-3 py-2 font-barlow text-xs sm:text-sm transition",
                                isOverlay ? "bg-white/60 hover:bg-white/80 ring-1 ring-black/10" : "bg-white hover:bg-neutral-50 ring-1 ring-black/10",
                                "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300",
                            ]}
                            data-ampel-close
                    >
                        Schließen
                    </button>
                </div>

                <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-2.5">
                    <div class:list={["rounded-xl ring-1 ring-black/10 p-3", isOverlay ? "bg-white/60" : "bg-white"]}>
                        <div class="font-barlow text-[11px] text-neutral-500">Pegelstand</div>
                        <div class="font-albert text-base sm:text-lg text-neutral-900" data-level>–</div>
                    </div>

                    <div class:list={["rounded-xl ring-1 ring-black/10 p-3", isOverlay ? "bg-white/60" : "bg-white"]}>
                        <div class="font-barlow text-[11px] text-neutral-500">Wassertemperatur</div>
                        <div class="font-albert text-base sm:text-lg text-neutral-900" data-temp>–</div>
                    </div>

                    <div class:list={["rounded-xl ring-1 ring-black/10 p-3", isOverlay ? "bg-white/60" : "bg-white"]}>
                        <div class="font-barlow text-[11px] text-neutral-500">Messzeitpunkt</div>
                        <div class="font-barlow text-xs sm:text-sm text-neutral-800" data-time>–</div>
                    </div>

                    <div class:list={["rounded-xl ring-1 ring-black/10 p-3", isOverlay ? "bg-white/60" : "bg-white"]}>
                        <div class="font-barlow text-[11px] text-neutral-500">Tendenz</div>
                        <div class="font-barlow text-xs sm:text-sm text-neutral-800" data-trend>–</div>
                    </div>
                </div>

                <div class="mt-2 font-barlow text-[11px] text-neutral-600" data-hint>
                    Daten werden geladen…
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        (() => {
            const API_BASE = "https://www.pegelonline.wsv.de/webservices/rest-api/v2";
            const STATION_UUID = "32807065-b887-49f0-935a-80033e5f3cb0";
            const FLOOD_CM = 360;

            const toggle = document.querySelector("[data-ampel-toggle]");
            const panel = document.querySelector("[data-ampel-panel]");
            const closeBtn = document.querySelector("[data-ampel-close]");
            const dot = document.querySelector("[data-ampel-dot]");

            const stationEl = document.querySelector("[data-station]");
            const levelEl = document.querySelector("[data-level]");
            const tempEl = document.querySelector("[data-temp]");
            const timeEl = document.querySelector("[data-time]");
            const trendEl = document.querySelector("[data-trend]");
            const hintEl = document.querySelector("[data-hint]");

            const lightRed = document.querySelector('[data-light="red"]');
            const lightYellow = document.querySelector('[data-light="yellow"]');
            const lightGreen = document.querySelector('[data-light="green"]');

            if (!toggle || !panel || !dot) return;

            const fmtDateTime = (iso) => {
                const d = new Date(iso);
                return new Intl.DateTimeFormat("de-DE", { dateStyle: "medium", timeStyle: "short" }).format(d);
            };

            const setDotColor = (color) => {
                dot.classList.remove("bg-neutral-300","bg-green-500","bg-yellow-400","bg-red-500","animate-pulse");
                if (color === "green") dot.classList.add("bg-green-500");
                else if (color === "yellow") dot.classList.add("bg-yellow-400");
                else if (color === "red") dot.classList.add("bg-red-500");
                else dot.classList.add("bg-neutral-300");
            };

            const setHousingActive = (color) => {
                const dim = "bg-neutral-500/40";
                [lightRed, lightYellow, lightGreen].forEach((el) => {
                    if (!el) return;
                    el.classList.remove("bg-red-500","bg-yellow-400","bg-green-500");
                    el.classList.add(dim);
                });
                if (color === "red" && lightRed) { lightRed.classList.remove(dim); lightRed.classList.add("bg-red-500"); }
                if (color === "yellow" && lightYellow) { lightYellow.classList.remove(dim); lightYellow.classList.add("bg-yellow-400"); }
                if (color === "green" && lightGreen) { lightGreen.classList.remove(dim); lightGreen.classList.add("bg-green-500"); }
            };

            const computeStatus = ({ levelCm, tempC }) => {
                if (typeof levelCm === "number" && levelCm >= FLOOD_CM) return "red";
                if (typeof tempC === "number" && tempC < 1) return "red";
                if (typeof tempC === "number" && tempC < 10) return "yellow";
                return "green";
            };

            const computeTrend = (values) => {
                if (!Array.isArray(values) || values.length < 2) return { label: "unbekannt", arrow: "•" };
                const a = values[values.length - 2]?.value;
                const b = values[values.length - 1]?.value;
                if (typeof a !== "number" || typeof b !== "number") return { label: "unbekannt", arrow: "•" };
                if (b > a) return { label: "steigend", arrow: "↗" };
                if (b < a) return { label: "sinkend", arrow: "↘" };
                return { label: "gleichbleibend", arrow: "→" };
            };

            const openPanel = () => {
                panel.classList.remove("hidden");
                panel.setAttribute("aria-hidden", "false");
                toggle.setAttribute("aria-expanded", "true");
                panel.classList.add("animate-[ruderampel-in_180ms_ease-out]");
            };

            const closePanel = () => {
                panel.classList.add("hidden");
                panel.setAttribute("aria-hidden", "true");
                toggle.setAttribute("aria-expanded", "false");
            };

            toggle.addEventListener("click", () => {
                const isOpen = toggle.getAttribute("aria-expanded") === "true";
                if (isOpen) closePanel();
                else openPanel();
            });

            closeBtn?.addEventListener("click", closePanel);
            document.addEventListener("keydown", (e) => { if (e.key === "Escape") closePanel(); });

            const fetchJson = async (url) => {
                const res = await fetch(url, { headers: { Accept: "application/json" } });
                if (!res.ok) throw new Error("HTTP " + res.status);
                return await res.json();
            };

            const load = async () => {
                try {
                    const stationUrl = `${API_BASE}/stations/${STATION_UUID}.json?includeTimeseries=true&includeCurrentMeasurement=true`;
                    const station = await fetchJson(stationUrl);

                    const ts = station?.timeseries ?? [];
                    const wTs =
                        ts.find((t) => t?.shortname === "W") ||
                        ts.find((t) => String(t?.longname || "").toLowerCase().includes("wasserstand"));

                    const tempTs =
                        ts.find((t) => String(t?.longname || "").toLowerCase().includes("wassertemperatur")) ||
                        ts.find((t) => String(t?.unit || "").includes("°C"));

                    const levelCm = wTs?.currentMeasurement?.value;
                    const levelTime = wTs?.currentMeasurement?.timestamp;
                    const tempC = tempTs?.currentMeasurement?.value;
                    const tempTime = tempTs?.currentMeasurement?.timestamp;

                    let trend = { label: "unbekannt", arrow: "•" };
                    if (wTs?.shortname) {
                        const mUrl = `${API_BASE}/stations/${STATION_UUID}/${wTs.shortname}/measurements.json?start=PT6H`;
                        const meas = await fetchJson(mUrl);
                        trend = computeTrend(meas);
                    }

                    const status = computeStatus({ levelCm, tempC });

                    setDotColor(status);
                    setHousingActive(status);

                    stationEl && (stationEl.textContent = station?.shortname ? `${station.shortname} (Lahn)` : "Leun (Lahn)");
                    levelEl && (levelEl.textContent = typeof levelCm === "number" ? `${Math.round(levelCm)} cm` : "—");
                    tempEl && (tempEl.textContent = typeof tempC === "number" ? `${tempC.toFixed(1).replace(".", ",")} °C` : "—");

                    const t = levelTime || tempTime;
                    timeEl && (timeEl.textContent = t ? fmtDateTime(t) : "—");
                    trendEl && (trendEl.textContent = `${trend.arrow} ${trend.label}`);

                    if (hintEl) {
                        if (status === "red") {
                            hintEl.textContent =
                                (typeof levelCm === "number" && levelCm >= FLOOD_CM)
                                    ? `Hochwasser: ab ${FLOOD_CM} cm rot. Ruderverbot`
                                    : `Sehr kalt: unter 1 °C rot. Ruderverbot`;
                        } else if (status === "yellow") {
                            hintEl.textContent = "Kaltwasser: 1–10 °C (gelb). Eingeschränkter Ruderbetrieb";
                        } else {
                            hintEl.textContent = "Normaler Ruderbetrieb (grün).";
                        }
                    }
                } catch (err) {
                    console.error("Ruderampel:", err);
                    setDotColor("unknown");
                    setHousingActive("unknown");
                    hintEl && (hintEl.textContent = "Daten konnten nicht geladen werden.");
                } finally {
                    dot.classList.remove("animate-pulse");
                }
            };

            // keyframes
            const style = document.createElement("style");
            style.textContent = `@keyframes ruderampel-in { from { transform: translateY(-6px); opacity: 0 } to { transform: translateY(0); opacity: 1 } }`;
            document.head.appendChild(style);

            load();
            setInterval(load, 5 * 60 * 1000);
        })();
    </script>
</div>

