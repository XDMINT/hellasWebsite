                                    let statusIcon = "✓";
                                    if (f.value >= FLOOD) {
                                        statusColor = "text-red-600";
                                        statusIcon = "⚠";
                                    } else if (f.value >= FLOOD - 50) {
                                        statusColor = "text-yellow-600";
                                        statusIcon = "!";
                                    }

                                    return `
                                        <div class="text-center bg-white rounded-lg p-3">
                                            <div class="font-barlow text-xs text-neutral-500">in ${f.hours}h</div>
                                            <div class="font-barlow text-xs text-neutral-400">${String(time.getHours()).padStart(2, '0')}:00</div>
                                            <div class="font-albert text-xl font-bold ${statusColor} mt-1">
                                                ${Math.round(f.value)} cm
                                            </div>
                                            <div class="font-barlow text-xs ${statusColor} mt-1">${statusIcon}</div>
                                        </div>
                                    `;
                                }).join("");

                                // Update Hinweistext basierend auf Datenquelle
                                const hintEl = document.querySelector("[data-water-forecast]")?.nextElementSibling;
                                if (hintEl && forecastData[0]?.isOfficial) {
                                    hintEl.textContent = "Offizielle Vorhersage von Pegelonline";
                                } else if (hintEl) {
                                    const method = window._ruderampelForecastMethod || "Statistisches Modell";
                                    const rainTotal = window._ruderampelRainTotal || 0;
                                    const rainSource = window._ruderampelRainSource || "Gießen";
                                    if (method === "ARIMAX") {
                                        hintEl.innerHTML = `Vorhersage: ARIMAX-Modell mit Niederschlagsdaten ${rainSource} (Ø ${rainTotal.toFixed(1)}mm/24h). <strong>⚠️ Bei extremen Wetterereignissen offizielle Hochwasservorhersage RLP beachten!</strong>`;
                                    } else {
                                        hintEl.textContent = "Prognose basierend auf aktuellem Trend und Niederschlagsvorhersage";
                                    }
                                }
                            }

                            // Zeichne Graph mit Prognose
                            if (isModalOpen) {
                                setTimeout(() => draw(measurements, forecastData), 100);
                            } else {
                                // Speichere auch Prognose für später
                                window._ruderampelForecast = forecastData;
                            }
                        } else {
                            console.error("Ruderampel: Messungen-API Error", measureResponse.status);
                        }
                     } catch (measureErr) {
                         console.error("Ruderampel: Fehler bei Messungen", measureErr);
                     }

                    // Forecast aktualisieren
                    const forecastEl = document.querySelector("[data-forecast]");
                    if (forecastEl && (weather?.hourly || weather?.minutely_15)) {
                        const controls = document.querySelector("[data-forecast-controls]");
                        const setActive = (rangeKey) => {
                            controls?.querySelectorAll("[data-forecast-range]").forEach(btn => {
                            const isActive = btn.getAttribute("data-forecast-range") === rangeKey;
                            btn.className = `px-3 py-1.5 rounded-lg text-xs font-barlow font-semibold ${isActive ? "bg-blue-600 text-white" : "bg-neutral-300 text-neutral-800"}`;
                        });
                        };

                        controls?.addEventListener("click", (e) => {
                            const target = e.target instanceof HTMLElement ? e.target.closest("[data-forecast-range]") : null;
                            if (!target) return;
                            const rangeKey = target.getAttribute("data-forecast-range") || "2h";
                            setActive(rangeKey);
                            renderWeatherForecast(weather, rangeKey);
                        });

                        setActive("2h");
                        renderWeatherForecast(weather, "2h");
                    }

                    console.log("Ruderampel: Erfolgreich geladen!");

                } catch (err) {
                    console.error("Ruderampel: Fehler beim Laden", err);
                    const hint = document.querySelector("[data-hint]");
                    if (hint) {
                        hint.textContent = `Fehler: ${err.message}`;
                    }
                    setColor("unknown");
                }
            };

            load();
            setInterval(load, 5 * 60 * 1000);
        })();
    </script>
</div>


