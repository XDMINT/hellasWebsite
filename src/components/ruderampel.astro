---
type Props = { class?: string; variant?: "default" | "overlay"; };
const { class: className = "", variant = "default" } = Astro.props as Props;
const isOverlay = variant === "overlay";
---

<div class:list={["w-fit", className]} data-ampel-root>
    <button type="button" class:list={["group inline-flex items-center justify-center rounded-2xl transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300 relative z-30 pointer-events-auto cursor-pointer", isOverlay ? "w-12 h-12 sm:w-14 sm:h-14 bg-transparent" : "w-12 h-12 sm:w-14 sm:h-14 bg-neutral-100 ring-1 ring-black/10 shadow-sm hover:shadow-md hover:bg-neutral-50", isOverlay ? "flex-col gap-1.5" : "flex-row"]} aria-label="Ruderampel öffnen" aria-haspopup="dialog" aria-expanded="false" data-ampel-toggle data-ampel-button>
         <span class="sr-only">Wassersportampel</span>
         {isOverlay ? (
             <span class="flex flex-col items-center gap-1.5 rounded-lg bg-neutral-900/90 p-2 ring-1 ring-black/40 shadow-inner transition group-hover:shadow-md group-hover:shadow-black/40">
                 <span class="block h-3 w-3 rounded-full bg-neutral-400/50" data-ampel-mini-light="red"></span>
                 <span class="block h-3 w-3 rounded-full bg-neutral-400/50" data-ampel-mini-light="yellow"></span>
                 <span class="block h-3 w-3 rounded-full bg-neutral-400/50" data-ampel-mini-light="green"></span>
             </span>
         ) : (
             <span class:list={["block rounded-full animate-pulse", "w-7 h-7", "bg-neutral-300"]} data-ampel-dot></span>
         )}
         {isOverlay ? (
            <span class="px-2 py-0.5 rounded-full text-[10px] font-barlow font-semibold bg-white/90 text-neutral-800 ring-1 ring-black/10 shadow-sm">Öffnen</span>
        ) : (
            <span class="ml-2 text-xs font-barlow text-neutral-600 hidden sm:inline">Öffnen</span>
        )}
     </button>

    <div id="ampel-modal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4" style="z-index: 9999999" data-ampel-modal>
         <div class="bg-white rounded-2xl shadow-2xl max-w-5xl w-full max-h-[90vh] overflow-y-auto" role="dialog">
             <div class="sticky top-0 bg-white border-b border-neutral-200 px-6 py-4 flex items-center justify-between rounded-t-2xl" style="z-index: 1000;">
                 <div class="flex items-center gap-4">
                     <div class="shrink-0 rounded-xl bg-neutral-900 p-2 shadow-inner">
                         <div class="flex flex-col gap-1.5">
                             <span class="block rounded-full w-5 h-5 bg-neutral-500/40" data-light="red"></span>
                             <span class="block rounded-full w-5 h-5 bg-neutral-500/40" data-light="yellow"></span>
                             <span class="block rounded-full w-5 h-5 bg-neutral-500/40" data-light="green"></span>
                         </div>
                     </div>
                     <div>
                         <h2 class="font-albert text-xl font-extrabold text-neutral-900">Wassersportampel</h2>
                         <p class="font-barlow text-sm text-neutral-600">Lahn-Pegel-Leun</p>
                     </div>
                 </div>
                 <button type="button" class="rounded-xl px-4 py-2 font-barlow text-sm font-semibold bg-neutral-100 hover:bg-neutral-200 ring-1 ring-black/10 transition" data-ampel-close>✕ Schließen</button>
             </div>

            <div class="p-6 space-y-6">
                <div class="rounded-xl p-4 ring-1" data-status-alert>
                    <div class="flex items-start gap-3">
                        <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center" data-status-icon><span class="text-2xl">●</span></div>
                        <div class="flex-1">
                            <div class="font-albert text-lg font-bold" data-status-title>Status wird geladen...</div>
                            <div class="font-barlow text-sm mt-1" data-hint>Daten werden abgerufen...</div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                    <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                        <div class="font-barlow text-xs text-neutral-500 uppercase tracking-wide">Pegelstand</div>
                        <div class="font-albert text-2xl font-bold text-neutral-900 mt-1" data-level>–</div>
                        <div class="font-barlow text-xs text-neutral-600 mt-1" data-trend>–</div>
                    </div>
                    <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                        <div class="font-barlow text-xs text-neutral-500 uppercase tracking-wide">Wassertemp.</div>
                        <div class="font-albert text-2xl font-bold text-neutral-900 mt-1" data-temp>–</div>
                    </div>
                    <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                        <div class="font-barlow text-xs text-neutral-500 uppercase tracking-wide">Lufttemp.</div>
                        <div class="font-albert text-2xl font-bold text-neutral-900 mt-1" data-air-temp>–</div>
                    </div>
                    <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                        <div class="font-barlow text-xs text-neutral-500 uppercase tracking-wide">Wetter</div>
                        <div class="font-barlow text-sm text-neutral-900 mt-1" data-weather>–</div>
                    </div>
                </div>

                <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                    <h3 class="font-albert text-base font-bold text-neutral-900 mb-3">Pegelverlauf & Prognose (48h)</h3>
                    <div class="relative h-80 bg-white rounded-lg p-3"><canvas id="water-chart"></canvas></div>
                    <div class="mt-2 font-barlow text-xs text-neutral-600">
                        <span class="inline-block mr-4">🔵 Historische Daten (24h)</span>
                        <span class="inline-block mr-4">🟠 Prognose (24h)</span>
                        <span class="inline-block">🔴 Hochwasser (360 cm)</span>
                    </div>
                    <div class="mt-1 font-barlow text-xs text-neutral-500">
                        Quelle: Pegelonline WSV (Pegelstände)
                    </div>
                </div>

                <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                    <h3 class="font-albert text-base font-bold text-neutral-900 mb-3">Pegel-Prognose (nächste 24h)</h3>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" data-water-forecast>
                        <div class="text-center bg-white rounded-lg p-3">
                            <div class="font-barlow text-xs text-neutral-500">Lade...</div>
                        </div>
                    </div>
                    <div class="mt-2 font-barlow text-xs text-neutral-600">
                        Prognose basierend auf aktuellem Trend und Niederschlagsvorhersage
                    </div>
                    <div class="mt-1 font-barlow text-xs text-neutral-500">
                        Quelle: Pegelonline WSV + Open-Meteo (Niederschlag)
                    </div>
                    <div class="mt-2">
                        <a href="https://www.hochwasser.rlp.de/flussgebiet/lahn/leun" target="_blank" rel="noopener" class="font-barlow text-xs text-blue-600 hover:text-blue-800 underline">
                            Offizielle Hochwasservorhersage RLP für Leun
                        </a>
                    </div>
                </div>

                <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                    <h3 class="font-albert text-base font-bold text-neutral-900 mb-3">Wettervorhersage Gießen</h3>
                    <div class="flex flex-wrap gap-2 mb-3" data-forecast-controls>
                        <button type="button" class="px-3 py-1.5 rounded-lg text-xs font-barlow font-semibold bg-blue-600 text-white" data-forecast-range="2h">2h</button>
                        <button type="button" class="px-3 py-1.5 rounded-lg text-xs font-barlow font-semibold bg-neutral-200 text-neutral-800" data-forecast-range="6h">6h</button>
                        <button type="button" class="px-3 py-1.5 rounded-lg text-xs font-barlow font-semibold bg-neutral-200 text-neutral-800" data-forecast-range="12h">12h</button>
                        <button type="button" class="px-3 py-1.5 rounded-lg text-xs font-barlow font-semibold bg-neutral-200 text-neutral-800" data-forecast-range="48h">2 Tage</button>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" data-forecast></div>
                    <div class="mt-2 font-barlow text-xs text-neutral-500">
                        Quelle: Open-Meteo (Gießen)
                    </div>
                </div>

                <div class="rounded-xl bg-neutral-50 ring-1 ring-black/10 p-4">
                    <h3 class="font-albert text-base font-bold text-neutral-900 mb-3">🌧️ Regenradar</h3>

                    <div class="relative bg-white rounded-lg overflow-hidden" style="height: 400px; position: relative; z-index: 1;">
                        <div id="radar-map" class="w-full h-full" style="position: relative; z-index: 1;"></div>
                        <div class="absolute bottom-2 left-2 bg-white/95 rounded-lg px-3 py-2 shadow-md font-barlow text-xs" style="z-index: 500; pointer-events: none;">
                            <span data-radar-timestamp>Lade Radar...</span>
                        </div>
                    </div>

                    <div class="mt-3 flex items-center gap-3">
                        <button type="button" class="shrink-0 w-10 h-10 rounded-lg bg-blue-600 text-white flex items-center justify-center hover:bg-blue-700 transition shadow-sm" data-radar-toggle aria-label="Animation starten/stoppen">
                            <span class="text-base" data-radar-icon>▶</span>
                        </button>

                        <div class="flex-1">
                            <div class="relative bg-neutral-200 rounded-full h-3 mb-1.5">
                                <div class="absolute top-0 left-0 h-full bg-blue-600 rounded-full transition-all duration-300" style="width: 0%;" data-radar-progress></div>
                                <div class="absolute top-0 left-0 h-full bg-yellow-400 rounded-full transition-all duration-300" style="width: 0%;" data-radar-progress-forecast></div>
                            </div>
                            <div class="flex justify-between font-barlow text-[10px] text-neutral-500 px-1" data-radar-timeline>
                                <span>Lade...</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-2 font-barlow text-xs text-neutral-500">
                        Quelle: Bright Sky / DWD (Deutscher Wetterdienst)
                    </div>
                </div>


                 <div class="rounded-xl bg-blue-50 ring-1 ring-blue-200 p-4">
                    <h3 class="font-albert text-base font-bold text-blue-900 mb-2">📋 Ruderregeln</h3>
                    <ul class="font-barlow text-sm text-blue-900 space-y-1">
                        <li>🔴 <strong>Rot:</strong> Wassersportverbot (Hochwasser &gt;360cm oder &lt;1°C)</li>
                        <li>🟡 <strong>Gelb:</strong> Eingeschränkter Betrieb (Kaltwasser 1-10°C)</li>
                        <li>🟢 <strong>Grün:</strong> Normaler Betrieb</li>
                    </ul>
                </div>

                <div class="text-center font-barlow text-xs text-neutral-500">Letzte Aktualisierung: <span data-time>–</span></div>
            </div>
        </div>
    </div>

    <script>
        // Initialisiere Bright Sky Radar wenn Modal geöffnet wird
        async function initRadarWhenReady() {
            console.log('⏳ Warte auf Radar-Modal...');

            const radarModal = document.querySelector("[data-ampel-modal]");
            if (!radarModal) {
                console.error('❌ Radar-Modal nicht gefunden');
                return;
            }

            console.log('Radar-Modal gefunden');
            let radarInitialized = false;

            const radarObserver = new MutationObserver(async () => {
                if (!radarModal.classList.contains("hidden") && !radarInitialized) {
                    radarInitialized = true;
                    console.log('Modal geöffnet - starte Radar-Init...');
                    try {
                        // Lade die Radar-Funktion direkt
                        await window.initBrightSkyRadar('radar-map');
                    } catch (err) {
                        console.error('❌ Radar-Init Fehler:', err);
                    }
                }
            });
            radarObserver.observe(radarModal, { attributes: true, attributeFilter: ['class'] });
        }

        // Starte wenn DOM ready ist
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initRadarWhenReady);
        } else {
            initRadarWhenReady();
        }
    </script>

    <script src="../lib/brightsky-radar.js"></script>

    <script is:inline define:vars={{ isOverlay }}>
        (() => {

            // ...Radar-Funktionen jetzt in brightsky-radar.js...

            const API = "https://www.pegelonline.wsv.de/webservices/rest-api/v2";
            const STATION = "32807065-b887-49f0-935a-80033e5f3cb0";
            const WEATHER = "https://api.open-meteo.com/v1/forecast";
            const FLOOD = 360;

            const weatherCodeToEmoji = (code) => {
                if (code === 0) return "☀️";
                if (code <= 2) return "🌤️";
                if (code <= 3) return "☁️";
                if (code >= 45 && code <= 48) return "🌫️";
                if (code >= 51 && code <= 67) return "🌧️";
                if (code >= 71 && code <= 77) return "❄️";
                if (code >= 80 && code <= 82) return "🌦️";
                if (code >= 95) return "⛈️";
                return "🌥️";
            };

            const windDirection = (deg) => {
                if (deg === null || deg === undefined) return "–";
                const dirs = ["N", "NE", "E", "SE", "S", "SW", "W", "NW"];
                const idx = Math.round(deg / 45) % 8;
                return dirs[idx];
            };

            const windArrow = (deg) => {
                if (deg === null || deg === undefined) return "•";
                if (deg >= 337.5 || deg < 22.5) return "↑";
                if (deg < 67.5) return "↗";
                if (deg < 112.5) return "→";
                if (deg < 157.5) return "↘";
                if (deg < 202.5) return "↓";
                if (deg < 247.5) return "↙";
                if (deg < 292.5) return "←";
                return "↖";
            };

            const formatTime = (date) => `${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;

            const formatDateWithDay = (date, rangeKey) => {
                const dayNames = ["So", "Mo", "Di", "Mi", "Do", "Fr", "Sa"];
                const day = dayNames[date.getDay()];
                const dateStr = `${String(date.getDate()).padStart(2, '0')}.${String(date.getMonth() + 1).padStart(2, '0')}.`;
                return `${dateStr} ${day}`;
            };

            const renderWeatherForecast = (weather, rangeKey = "2h") => {
                const forecastEl = document.querySelector("[data-forecast]");
                if (!forecastEl) return;

                const hourly = weather?.hourly || {};
                const minutely = weather?.minutely_15 || {};

                const useMinutely = rangeKey === "2h" && Array.isArray(minutely.temperature_2m);

                const getSeries = (key) => {
                    const minSeries = minutely[key];
                    const hourSeries = hourly[key];
                    if (useMinutely && Array.isArray(minSeries)) return minSeries;
                    return Array.isArray(hourSeries) ? hourSeries : [];
                };

                const temps = getSeries("temperature_2m");
                const codes = getSeries("weather_code");
                const precip = getSeries("precipitation");
                const precipProb = getSeries("precipitation_probability");
                const uv = getSeries("uv_index");
                const wind = getSeries("wind_speed_10m");
                const windDir = getSeries("wind_direction_10m");

                let indices = [];
                if (rangeKey === "2h") {
                    indices = useMinutely ? [0, 2, 4, 6] : [0, 1, 2, 3];
                } else if (rangeKey === "6h") {
                    indices = [0, 2, 4, 6];
                } else if (rangeKey === "12h") {
                    indices = [0, 4, 8, 12];
                } else {
                    // 2 Tage: Filter auf verfügbare Indizes (array length prüfen)
                    const maxIndex = Math.min(temps.length - 1, 47); // Max 48h verfügbar
                    indices = [0, 12, 24, Math.max(36, maxIndex)]; // Letzter Index muss gültig sein
                }

                forecastEl.innerHTML = indices.map((i) => {
                    const t = i < temps.length ? temps[i] : null;
                    const code = i < codes.length ? codes[i] : null;
                    const p = i < precip.length ? precip[i] : 0;
                    const pp = i < precipProb.length ? precipProb[i] : null;
                    const uvIndex = i < uv.length ? uv[i] : null;
                    const w = i < wind.length ? wind[i] : null;
                    const wd = i < windDir.length ? windDir[i] : null;

                    const emoji = weatherCodeToEmoji(code ?? 0);
                    const time = new Date();
                    if (useMinutely) {
                        time.setMinutes(time.getMinutes() + (i * 15));
                    } else {
                        time.setHours(time.getHours() + i);
                        time.setMinutes(0, 0, 0);
                    }

                    const isRain = (code !== null && code >= 51) || p > 0.1;
                    const isSunny = code === 0 || code === 1 || code === 2;

                    const rainLine = isRain
                        ? `🌧️ ${pp !== null ? `${pp}%` : "–"} · ${p.toFixed(1)} mm`
                        : "";
                    const uvLine = isSunny
                        ? `☀️ UV ${uvIndex !== null ? uvIndex.toFixed(1) : "–"}`
                        : "";
                    const windLine = `💨 ${w !== null ? w.toFixed(0) : "–"} km/h ${windArrow(wd)} ${windDirection(wd)}`;

                    // Zeige Datum nur bei 6h, 12h, 48h
                    const showDate = rangeKey === "6h" || rangeKey === "12h" || rangeKey === "48h";
                    const timeDisplay = showDate ? `<div class="font-barlow text-xs text-neutral-400">${formatDateWithDay(time, rangeKey)}</div><div class="font-barlow text-xs text-neutral-500">${formatTime(time)}</div>` : `<div class="font-barlow text-xs text-neutral-500">${formatTime(time)}</div>`;

                    return `<div class="text-center bg-white rounded-lg p-3">
                        ${timeDisplay}
                        <div class="font-albert text-xl font-bold">${t !== null ? t.toFixed(0) : "–"}°C</div>
                        <div class="font-barlow text-lg mt-1">${emoji}</div>
                        ${rainLine ? `<div class="font-barlow text-xs text-blue-700 mt-1">${rainLine}</div>` : ""}
                        ${uvLine ? `<div class="font-barlow text-xs text-yellow-700 mt-1">${uvLine}</div>` : ""}
                        <div class="font-barlow text-xs text-neutral-600 mt-1">${windLine}</div>
                    </div>`;
                }).join("");
            };

            const toggle = document.querySelector("[data-ampel-toggle]");
            const modal = document.querySelector("[data-ampel-modal]");
            const close = document.querySelector("[data-ampel-close]");
            const dot = document.querySelector("[data-ampel-dot]");
            const button = document.querySelector("[data-ampel-button]");
            const miniLights = Array.from(document.querySelectorAll("[data-ampel-mini-light]"));

            if (!toggle || !modal || (!dot && miniLights.length === 0)) {
                console.error("Ruderampel: Fehlende DOM-Elemente");
                return;
            }

            let measurements = null; // Cache für Messungen
            let isModalOpen = false;

            toggle.addEventListener("click", () => {
                modal.classList.remove("hidden");
                modal.setAttribute("aria-hidden", "false");
                toggle.setAttribute("aria-expanded", "true");
                isModalOpen = true;

                // Zeichne Graph neu wenn Modal geöffnet wird
                setTimeout(() => {
                    if (measurements && measurements.length > 0) {
                        const forecast = window._ruderampelForecast || null;
                        draw(measurements, forecast);
                    }
                }, 100); // Kurze Verzögerung damit Canvas Größe hat
            });

            close?.addEventListener("click", () => {
                modal.classList.add("hidden");
                modal.setAttribute("aria-hidden", "true");
                toggle.setAttribute("aria-expanded", "false");
                isModalOpen = false;
            });

            modal.addEventListener("click", e => {
                if (e.target === modal) {
                    modal.classList.add("hidden");
                    modal.setAttribute("aria-hidden", "true");
                    toggle.setAttribute("aria-expanded", "false");
                    isModalOpen = false;
                }
            });

            const setColor = (c) => {
                if (dot) {
                    // Entferne alle Farb-Klassen
                    dot.classList.remove("bg-neutral-300", "bg-red-500", "bg-yellow-400", "bg-green-500");

                    // Füge die richtige Farbe hinzu
                    if (c === "red") dot.classList.add("bg-red-500");
                    else if (c === "yellow") dot.classList.add("bg-yellow-400");
                    else if (c === "green") dot.classList.add("bg-green-500");
                    else dot.classList.add("bg-neutral-300");
                }

                if (miniLights.length > 0) {
                    miniLights.forEach(light => {
                        light.classList.remove("bg-red-500", "bg-yellow-400", "bg-green-500");
                        light.classList.add("bg-neutral-400/50");
                    });

                    const active = miniLights.find(light => light.getAttribute("data-ampel-mini-light") === c);
                    if (active) {
                        active.classList.remove("bg-neutral-400/50");
                        if (c === "red") active.classList.add("bg-red-500");
                        else if (c === "yellow") active.classList.add("bg-yellow-400");
                        else if (c === "green") active.classList.add("bg-green-500");
                    }
                }

                if (isOverlay && button) {
                    button.classList.remove("ring-red-400/70", "ring-yellow-300/70", "ring-green-400/70");
                    if (c === "red") button.classList.add("ring-red-400/70");
                    else if (c === "yellow") button.classList.add("ring-yellow-300/70");
                    else if (c === "green") button.classList.add("ring-green-400/70");
                }

                // Update Ampel-Lichter im Modal
                const lights = {
                    r: document.querySelector('[data-light="red"]'),
                    y: document.querySelector('[data-light="yellow"]'),
                    g: document.querySelector('[data-light="green"]')
                };

                Object.values(lights).forEach(light => {
                    if (light) {
                        light.classList.remove("bg-red-500", "bg-yellow-400", "bg-green-500");
                        light.classList.add("bg-neutral-500/40");
                    }
                });

                if (c === "red" && lights.r) {
                    lights.r.classList.remove("bg-neutral-500/40");
                    lights.r.classList.add("bg-red-500");
                }
                if (c === "yellow" && lights.y) {
                    lights.y.classList.remove("bg-neutral-500/40");
                    lights.y.classList.add("bg-yellow-400");
                }
                if (c === "green" && lights.g) {
                    lights.g.classList.remove("bg-neutral-500/40");
                    lights.g.classList.add("bg-green-500");
                }
            };

            const draw = (data, forecast = null) => {
                if (!data || data.length === 0) {
                    console.log("Ruderampel: Keine Daten für Graph");
                    return;
                }

                const canvas = document.getElementById("water-chart");
                if (!canvas) {
                    console.error("Ruderampel: Canvas nicht gefunden");
                    return;
                }

                const ctx = canvas.getContext("2d");
                if (!ctx) {
                    console.error("Ruderampel: Canvas Context nicht verfügbar");
                    return;
                }

                // Setze Canvas-Größe basierend auf Container
                const container = canvas.parentElement;
                const displayW = container.offsetWidth - 24;
                const displayH = container.offsetHeight - 24;

                // HiDPI/Retina Support - 2x Auflösung für scharfe Darstellung
                const dpr = window.devicePixelRatio || 1;
                canvas.width = displayW * dpr;
                canvas.height = displayH * dpr;
                canvas.style.width = displayW + 'px';
                canvas.style.height = displayH + 'px';
                ctx.scale(dpr, dpr);

                const w = displayW;
                const h = displayH;

                // Margins für Achsen - Responsive basierend auf Canvas-Breite
                const isSmall = w < 500;
                const marginLeft = isSmall ? 45 : 60;
                const marginRight = isSmall ? 15 : 30;
                const marginTop = isSmall ? 25 : 40;
                const marginBottom = isSmall ? 45 : 60;
                const plotW = w - marginLeft - marginRight;
                const plotH = h - marginTop - marginBottom;

                ctx.clearRect(0, 0, w, h);

                // Kombiniere historische Daten und Prognose zu einem durchgehenden Zeitstrahl
                const allData = [...data];
                let splitIndex = data.length; // Wo die Prognose beginnt

                if (forecast && forecast.length > 0) {
                    // Prüfe ob stündliche Vorhersage verfügbar ist (für glattere Kurve)
