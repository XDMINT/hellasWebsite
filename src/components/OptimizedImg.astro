---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata | string;
  alt: string;
  title?: string;
  className?: string;
  width?: number;
  height?: number;
  aspectRatio?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync";
  credit?: string;
}

const {
  src,
  alt,
  title,
  className = "",
  width,
  height,
  aspectRatio,
  loading = "lazy",
  decoding = "async",
  credit,
} = Astro.props;

// Prüfe ob es ein lokales Asset ist (ImageMetadata) oder externe URL
const isLocalAsset = typeof src !== "string";

// Wenn lokales Asset: nutze <Image> für Optimierung
// Wenn externe URL: nutze normales <img>
---

{credit ? (
  <figure class="relative w-full h-full">
    {isLocalAsset ? (
      <Image
        src={src}
        alt={alt}
        title={title}
        class={`${className} object-cover w-full block`}
        {...(width && { width })}
        {...(height && { height })}
        loading={loading}
        decoding={decoding}
      />
    ) : (
      <img
        src={src}
        alt={alt}
        title={title}
        class={`${className} object-cover w-full block`}
        style={aspectRatio ? `aspect-ratio: ${aspectRatio}` : ""}
        {...(width && { width })}
        {...(height && { height })}
        loading={loading}
        decoding={decoding}
      />
    )}
    <figcaption class="absolute bottom-2 right-2 rounded bg-black/60 px-2 py-0.5 font-barlow text-[10px] text-white">
      {credit}
    </figcaption>
  </figure>
) : isLocalAsset ? (
  <Image
    src={src}
    alt={alt}
    title={title}
    class={`${className} object-cover w-full block`}
    {...(width && { width })}
    {...(height && { height })}
    loading={loading}
    decoding={decoding}
  />
) : (
  <img
    src={src}
    alt={alt}
    title={title}
    class={`${className} object-cover w-full block`}
    style={aspectRatio ? `aspect-ratio: ${aspectRatio}` : ""}
    {...(width && { width })}
    {...(height && { height })}
    loading={loading}
    decoding={decoding}
  />
)}
