---
// src/components/Header.astro
import OptimizedImg from "./OptimizedImg.astro";
import { logo } from "../assets/images";

type NavLink = { href: string; label: string };

const {
    logoSrc = logo,
    logoAlt = "WSV Hellas 1920 Gießen e. V.",
    links = [
        { href: "/", label: "Home" },
        { href: "/news", label: "News" },
        { href: "/rudern", label: "Rudern" },
        { href: "/drachenboot", label: "Drachenboot" },
        { href: "/allgemeines-sportangebot", label: "Allgemeines Sportangebot" },
        { href: "/trainingszeiten", label: "Trainingszeiten" },
        { href: "/vorstand", label: "Vorstand" },
    ] satisfies NavLink[],
} = Astro.props as {
    logoSrc?: any;
    logoAlt?: string;
    links?: NavLink[];
};

const normalize = (p: string) => (p.length > 1 && p.endsWith("/") ? p.slice(0, -1) : p);
const pathname = normalize(Astro.url?.pathname ?? "/");

const shouldPrefetch = (href: string) => normalize(href) === "/news" && pathname !== "/news";

const isActive = (href: string) => {
    const h = normalize(href);
    if (h === "/") return pathname === "/";
    return pathname === h || pathname.startsWith(h + "/");
};
---

<header class="sticky lg:static z-50 transition-none" data-hellas-header>
    <!-- Mobile wrapper: becomes floating pill on scroll -->
    <div class="lg:hidden mobile-header border-b border-gray-200 relative overflow-visible bg-white" data-mobile-header>
        <div class="flex items-center justify-between h-16 px-4">
            <!-- Logo -->
            <a href="/" aria-label="Zur Startseite" class="inline-flex items-center">
                <OptimizedImg
                        src={logoSrc}
                        alt={logoAlt}
                        className="h-14 sm:h-16 w-auto block"
                        loading="eager"
                        widths={[80, 120, 160]}
                        sizes="80px"
                />
            </a>

            <!-- Mobile hamburger (3-Linien → X Rotation) -->
            <button
                    type="button"
                    class="flex flex-col gap-1.5 p-2 hover:bg-neutral-50 rounded-xl transition
                           ring-1 ring-black/10
                           focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300"
                    aria-label="Menü öffnen"
                    aria-controls="mobile-menu"
                    aria-expanded="false"
                    data-menu-button
            >
                <span class="w-5 h-0.5 bg-neutral-800 transition-all duration-300 block" data-bar-1></span>
                <span class="w-5 h-0.5 bg-neutral-800 transition-all duration-300 block" data-bar-2></span>
                <span class="w-5 h-0.5 bg-neutral-800 transition-all duration-300 block" data-bar-3></span>
            </button>
        </div>

        <!-- Mobile nav: drops out below the header pill, absolute -->
        <nav
                id="mobile-menu"
                aria-label="Mobile Hauptnavigation"
                aria-hidden="true"
                data-menu-panel
                class="mobile-nav"
        >
            <div class="px-4 py-4 space-y-2">
                <ul class="m-0 p-0 list-none flex flex-col gap-2">
                    {links.map((l) => {
                        const active = isActive(l.href);
                        return (
                                <li>
                                    <a
                                            href={l.href}
                                            data-astro-prefetch={shouldPrefetch(l.href) ? "load" : undefined}
                                            aria-current={active ? "page" : undefined}
                                            class:list={[
                                                "font-albert font-bold text-base rounded-xl px-4 py-3 block no-underline transition",
                                                active
                                                    ? "bg-blue-600 text-white"
                                                    : "bg-white text-neutral-900 ring-1 ring-black/10 hover:bg-blue-50",
                                                "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300",
                                            ]}
                                    >
                                        {l.label}
                                    </a>
                                </li>
                        );
                    })}
                </ul>
            </div>
        </nav>
    </div>

    <!-- Desktop header (unverändert) -->
    <div class="hidden lg:block bg-white border-b border-black/10">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <div class="relative flex flex-col items-center pt-4">
                <div class="w-full flex items-center justify-center pb-0">
                    <a href="/" aria-label="Zur Startseite" class="inline-flex items-center">
                        <OptimizedImg
                                src={logoSrc}
                                alt={logoAlt}
                                className="h-20 w-auto block"
                                loading="eager"
                                widths={[80, 120, 160]}
                                sizes="80px"
                        />
                    </a>
                </div>

                <nav aria-label="Hauptnavigation" class="mt-6 mb-6">
                    <ul class="m-0 p-0 list-none flex flex-wrap justify-center gap-12">
                        {links.map((l) => {
                            const active = isActive(l.href);
                            return (
                                    <li>
                                        <a
                                                href={l.href}
                                                data-astro-prefetch={shouldPrefetch(l.href) ? "viewport" : undefined}
                                                aria-current={active ? "page" : undefined}
                                                class:list={[
                                                    "relative inline-block pb-2 text-lg font-albert font-bold leading-none text-neutral-900 no-underline",
                                                    "after:content-[''] after:absolute after:left-0 after:right-0 after:bottom-0 after:h-1 after:rounded-full after:bg-blue-500",
                                                    "after:origin-left after:scale-x-0 after:transition-transform after:duration-150 after:ease-out",
                                                    "hover:after:scale-x-100 focus-visible:after:scale-x-100",
                                                    active && "after:scale-x-100",
                                                    "focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-blue-300 rounded-lg",
                                                ]}
                                        >
                                            {l.label}
                                        </a>
                                    </li>
                            );
                        })}
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</header>

<style>
    /* Kein Transition auf dem sticky header selbst – nur Mobile */
    @media (max-width: 1023px) {
        [data-hellas-header] {
            top: 0;
            transition: none !important;
        }
    }

    /* ── Mobile floating-pill ── */
    .mobile-header {
        overflow: visible;
    }

    .mobile-header.smooth-radius {
        transition:
            border-top-left-radius 0.25s ease-out 0.15s,
            border-top-right-radius 0.25s ease-out 0.15s,
            border-bottom-left-radius 0.25s ease-out 0.15s,
            border-bottom-right-radius 0.25s ease-out 0.15s;
    }

    /* ── Mobile nav drop-down ── */
    .mobile-nav {
        max-height: 0;
        overflow: hidden;
        transition:
            max-height 0.4s ease-in-out,
            padding 0.4s ease-in-out,
            border 0.4s ease-in-out;
        padding: 0;
        border-top: 0px solid rgba(209, 213, 219, 0.3);
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        width: 100%;
        pointer-events: none;
        background-color: white;
        border-bottom-left-radius: 1.25rem;
        border-bottom-right-radius: 1.25rem;
        margin-top: -0.25rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        z-index: 50;
    }

    .mobile-nav.open {
        max-height: 600px;
        border-top: 1px solid rgba(209, 213, 219, 0.3);
        padding: 1rem;
        pointer-events: auto;
    }

    /* ── Burger → X animation ── */
    [data-menu-button].open [data-bar-1] {
        transform: rotate(45deg) translate(7px, 7px);
    }
    [data-menu-button].open [data-bar-2] {
        opacity: 0;
    }
    [data-menu-button].open [data-bar-3] {
        transform: rotate(-45deg) translate(6px, -6px);
    }
</style>

<script>
    const navToggle    = document.querySelector('[data-menu-button]') as HTMLElement | null;
    const mobileNav    = document.querySelector('[data-menu-panel]') as HTMLElement | null;
    const mobileHeader = document.querySelector('[data-mobile-header]') as HTMLElement | null;
    const header       = document.querySelector('[data-hellas-header]') as HTMLElement | null;

    let navIsOpen = false;

    if (mobileHeader && header) {
        const START = 40;
        const RANGE = 100;

        function applyScrollStyles(sy: number) {
            const progress = Math.min(Math.max((sy - START) / RANGE, 0), 1);
            const margin   = progress * 16;
            const radius   = progress * 20;
            const top      = progress * 12;
            const shadowBlur    = progress * 40;
            const shadowSpread  = progress * -8;
            const shadowOpacity = progress * 0.25;

            mobileHeader!.style.marginLeft  = `${margin}px`;
            mobileHeader!.style.marginRight = `${margin}px`;
            mobileHeader!.style.boxShadow   = navIsOpen
                ? 'none'
                : `0 ${shadowBlur * 0.5}px ${shadowBlur}px ${shadowSpread}px rgba(0,0,0,${shadowOpacity.toFixed(2)})`;
            mobileHeader!.style.borderColor = progress >= 1
                ? 'transparent'
                : `rgba(209,213,219,${(1 - progress).toFixed(2)})`;
            header!.style.top = `${top}px`;

            const bottomRadius = navIsOpen ? '0px' : `${radius}px`;
            mobileHeader!.style.borderTopLeftRadius     = `${radius}px`;
            mobileHeader!.style.borderTopRightRadius    = `${radius}px`;
            mobileHeader!.style.borderBottomLeftRadius  = bottomRadius;
            mobileHeader!.style.borderBottomRightRadius = bottomRadius;
        }

        window.addEventListener('scroll', () => {
            mobileHeader!.classList.remove('smooth-radius');
            header!.style.transition = 'none';
            applyScrollStyles(window.scrollY);
        }, { passive: true });

        if (navToggle && mobileNav) {
            navToggle.addEventListener('click', () => {
                navToggle.classList.toggle('open');
                mobileNav.classList.toggle('open');
                const isNowOpen = mobileNav.classList.contains('open');
                navToggle.setAttribute('aria-expanded', String(isNowOpen));
                navToggle.setAttribute('aria-label', isNowOpen ? 'Menü schließen' : 'Menü öffnen');
                mobileNav.setAttribute('aria-hidden', String(!isNowOpen));
                if (isNowOpen) {
                    navIsOpen = true;
                    mobileHeader!.classList.remove('smooth-radius');
                    applyScrollStyles(window.scrollY);
                } else {
                    navIsOpen = false;
                    mobileHeader!.classList.add('smooth-radius');
                    applyScrollStyles(window.scrollY);
                    setTimeout(() => mobileHeader!.classList.remove('smooth-radius'), 400);
                }
            });

            const links = mobileNav.querySelectorAll('a');
            links.forEach(link => {
                link.addEventListener('click', () => {
                    navToggle.classList.remove('open');
                    mobileNav.classList.remove('open');
                    navToggle.setAttribute('aria-expanded', 'false');
                    navToggle.setAttribute('aria-label', 'Menü öffnen');
                    mobileNav.setAttribute('aria-hidden', 'true');
                    navIsOpen = false;
                    mobileHeader!.classList.add('smooth-radius');
                    applyScrollStyles(window.scrollY);
                    setTimeout(() => mobileHeader!.classList.remove('smooth-radius'), 400);
                });
            });

            document.addEventListener('keydown', (e: KeyboardEvent) => {
                if (e.key === 'Escape' && mobileNav.classList.contains('open')) {
                    navToggle.classList.remove('open');
                    mobileNav.classList.remove('open');
                    navToggle.setAttribute('aria-expanded', 'false');
                    navToggle.setAttribute('aria-label', 'Menü öffnen');
                    mobileNav.setAttribute('aria-hidden', 'true');
                    navIsOpen = false;
                    mobileHeader!.classList.add('smooth-radius');
                    applyScrollStyles(window.scrollY);
                    setTimeout(() => mobileHeader!.classList.remove('smooth-radius'), 400);
                }
            });

            mobileNav.addEventListener('transitionend', (e: TransitionEvent) => {
                if (e.propertyName === 'max-height' && !mobileNav.classList.contains('open')) {
                    navIsOpen = false;
                    applyScrollStyles(window.scrollY);
                }
            });
        }
    }
</script>



